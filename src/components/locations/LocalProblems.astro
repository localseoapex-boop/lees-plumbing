---
/**
 * LocalProblems.astro — "Common Home Service Problems in [City]".
 *
 * The primary SEO section on a city page. Two groups (plumbing, heating and
 * cooling), each a list of real problems a Cache Valley homeowner runs into.
 *
 * The content is about the VALLEY, not about invented street-level knowledge of
 * one town. That is a deliberate honesty constraint, not a shortcut: all nine
 * cities share the same climate, the same hard water, and the same office, so
 * claiming distinct expertise in each would be fabricating a difference that does
 * not exist. See the note at the top of data/location-content.ts.
 */
import type { ContentPoint } from '../../data/service-content';

export interface ProblemGroupView {
  title: string;
  items: ContentPoint[];
}

interface Props {
  id: string;
  heading: string;
  intro?: string;
  groups: ProblemGroupView[];
}

const { id, heading, intro, groups } = Astro.props;
const headingId = `${id}-heading`;
---

<section class="problems" {id} aria-labelledby={headingId}>
  <div class="container">
    <header class="section-head">
      <h2 id={headingId}>{heading}</h2>
      {intro && <p class="section-intro">{intro}</p>}
    </header>

    <div class="groups">
      {
        groups.map((group) => (
          <div class="group">
            <h3 class="group-title">{group.title}</h3>
            <ul class="problem-list">
              {group.items.map((item) => (
                <li class="problem">
                  <h4>{item.title}</h4>
                  <p>{item.body}</p>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .problems {
    background: var(--color-surface-alt);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: var(--section-y) 0;
  }
  .section-head {
    max-width: 64ch;
    margin-bottom: clamp(2rem, 4vw, 2.75rem);
  }
  h2 {
    font-size: clamp(2rem, 3.4vw, 2.75rem);
    margin: 0 0 0.75rem;
    text-wrap: balance;
  }
  .section-intro {
    margin: 0;
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .groups {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(2rem, 4vw, 3rem);
  }
  .group-title {
    font-size: 1.5rem;
    margin: 0 0 1.25rem;
    padding-bottom: 0.6rem;
    border-bottom: 2px solid var(--color-red);
    display: inline-block;
  }

  .problem-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .problem + .problem {
    margin-top: 1.35rem;
    padding-top: 1.35rem;
    border-top: 1px solid var(--color-border);
  }
  .problem h4 {
    font-size: 1.15rem;
    margin: 0 0 0.4rem;
  }
  .problem p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  @media (max-width: 860px) {
    .groups {
      grid-template-columns: 1fr;
    }
  }
</style>
