---
/**
 * AboutSection.astro — compact split-layout company introduction.
 *
 * Short by design. The `paragraphs` array is the growth point: real company
 * history drops straight in as additional entries without touching this file.
 * `highlights` is for verifiable facts only, never claims.
 */
interface Props {
  id: string;
  heading: string;
  paragraphs: readonly string[];
  highlights?: readonly string[];
  ctaLabel?: string;
  ctaHref?: string;
}

const { id, heading, paragraphs, highlights = [], ctaLabel, ctaHref } = Astro.props;
const headingId = `${id}-heading`;
---

<section class="about" aria-labelledby={headingId}>
  <div class="container about-inner">
    <div class="about-copy">
      <h2 id={headingId}>{heading}</h2>
      {paragraphs.map((text) => <p>{text}</p>)}
      {
        ctaLabel && ctaHref && (
          <a class="btn-outline" href={ctaHref}>
            {ctaLabel}
          </a>
        )
      }
    </div>

    {
      highlights.length > 0 && (
        <aside class="about-highlights" aria-label="Company facts">
          <ul>
            {highlights.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </aside>
      )
    }
  </div>
</section>

<style>
  .about {
    background: var(--color-white);
    padding: var(--section-y) 0;
  }
  .about-inner {
    display: grid;
    grid-template-columns: 1.4fr 0.6fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  h2 {
    font-size: clamp(2rem, 3.4vw, 2.75rem);
    margin: 0 0 1.25rem;
  }
  .about-copy p {
    margin: 0 0 1.1rem;
    font-size: 1.075rem;
    line-height: 1.75;
    color: var(--color-muted);
    max-width: 62ch;
  }
  .btn-outline {
    display: inline-block;
    margin-top: 0.75rem;
    padding: 0.9rem 1.6rem;
    border: 2px solid var(--color-red);
    border-radius: var(--radius-sm);
    color: var(--color-red);
    font-weight: 600;
    text-decoration: none;
    transition:
      background-color 0.18s ease,
      color 0.18s ease;
  }
  .btn-outline:hover {
    background: var(--color-red);
    color: var(--color-white);
  }

  .about-highlights {
    padding: 1.6rem;
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }
  .about-highlights ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.9rem;
  }
  .about-highlights li {
    position: relative;
    padding-left: 1.4rem;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-dark);
  }
  .about-highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-red);
  }

  @media (max-width: 900px) {
    .about-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
