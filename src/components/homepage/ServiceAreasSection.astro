---
/**
 * ServiceAreasSection.astro — headquarters anchor + a balanced city directory.
 *
 * Every city page in the location architecture gets a real, crawlable link from
 * the homepage, which is what makes this section worth its space for local SEO.
 *
 * LAYOUT. The list is a three-column grid. The headquarters city is rendered as
 * a FULL-WIDTH lead row above a clean 3x3 of the linked cities, so the section
 * reads as "home base, then the communities it reaches" rather than as ten
 * identical boxes. With nine linked cities that 3x3 is exact, so there is never a
 * ragged orphan row at desktop or tablet width.
 *
 * ORDER. Cities render in the order the caller provides (locations.ts). The FIRST
 * item flagged `isHeadquarters` is treated as the featured row; nothing is sorted
 * here. For this site the headquarters is already first, so it leads the grid
 * naturally.
 *
 * HEADQUARTERS. Distinguished only through layout, spacing, typography, badge,
 * and a subtle background: no page to link to, so it is a plain, non-interactive
 * element with no hover affordance. It is the most prominent element in the
 * section, not a dimmed or disabled one, so its lack of a link reads as "you are
 * describing home base," never as broken.
 */
export interface AreaCard {
  city: string;
  region: string;
  /**
   * Destination, or null for a city with no page of its own.
   *
   * Hyde Park is the headquarters and is covered directly by the homepage and
   * the core service pages, so it generates no /locations/ page. It still
   * belongs in this grid as the anchor of the service area, so a null href
   * renders the card as plain, non-interactive text rather than as a link to a
   * page that does not exist. The badge and emphasis are unchanged.
   */
  href: string | null;
  isHeadquarters?: boolean;
}

interface Props {
  id: string;
  heading: string;
  intro?: string;
  areas: AreaCard[];
  headquartersLabel?: string;
}

const { id, heading, intro, areas, headquartersLabel = 'Headquarters' } = Astro.props;
const headingId = `${id}-heading`;
// The FIRST headquarters item is the featured lead. Found by index so a second
// flagged item (should never happen) cannot also steal the full-width row.
const featuredIndex = areas.findIndex((area) => area.isHeadquarters);
---

<section class="areas" {id} aria-labelledby={headingId}>
  <div class="container">
    <header class="section-head">
      {/* The same red accent the About, Trust and Plumbing bands open with, so
          this section finally rhymes with the rest of the page. Decorative, so
          it is hidden from assistive technology. */}
      <span class="head-rule" aria-hidden="true"></span>
      <h2 id={headingId}>{heading}</h2>
      {intro && <p class="section-intro">{intro}</p>}
    </header>

    <ul class="area-grid">
      {
        areas.map((area, i) => {
          const featured = area.isHeadquarters && i === featuredIndex;
          const Tag = area.href ? 'a' : 'div';
          return (
            <li class:list={['area-item', { 'is-featured': featured }]}>
              <Tag
                class:list={['area-card', area.isHeadquarters && 'is-hq', !area.href && 'is-static']}
                href={area.href ?? undefined}
              >
                <span class="area-city">
                  {area.city}, {area.region}
                </span>
                {area.isHeadquarters && <span class="area-badge">{headquartersLabel}</span>}
              </Tag>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>

<style>
  .areas {
    background: var(--color-white);
    padding: var(--section-y) 0;
    /* The section is an in-page anchor target on the service hubs, so keep the
       heading clear of the viewport top when a CTA jumps here. */
    scroll-margin-top: 1.5rem;
  }
  .section-head {
    max-width: 62ch;
    margin-bottom: clamp(2rem, 4vw, 2.75rem);
  }
  .head-rule {
    display: block;
    width: 40px;
    height: 3px;
    border-radius: 2px;
    background: var(--color-red);
    margin-bottom: 1.25rem;
  }
  h2 {
    font-size: clamp(2rem, 3.4vw, 2.75rem);
    margin: 0 0 0.75rem;
    text-wrap: balance;
  }
  .section-intro {
    margin: 0;
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  /* THE FRAMED DIRECTORY.
     The whole list is one editorial object: an outer hairline frame with 1px
     dividers between every cell. Both are drawn the seam-free way — a 1px grid
     GAP over a border-coloured backing, with white cells sitting on top — so
     there are no doubled borders where cells meet and no per-card box. The frame
     carries the structure that nine shadowed, hovering cards used to, which is
     what turns a styled link directory into a considered service register. Nine
     linked cities fill an exact 3x3 beneath the full-width headquarters row, so
     no width produces a ragged final row. */
  .area-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    /* Clip the inner cells to the rounded frame. Also WHY the focus ring below
       is inset: a positive outline-offset would be clipped by this. */
    overflow: hidden;
  }
  .area-item {
    display: flex;
  }
  /* The headquarters leads as a full-width anchor row; the 1px gap beneath it
     becomes the hairline that separates home base from the communities. */
  .area-item.is-featured {
    grid-column: 1 / -1;
  }

  .area-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    /* Wrap rather than squeeze: on a narrow track the badge drops to its own
       line instead of crushing the city name into two cramped lines. */
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    width: 100%;
    height: 100%;
    padding: 1.15rem 1.35rem;
    background: var(--color-white);
    text-decoration: none;
    color: var(--color-dark);
    font-weight: 600;
    transition:
      background-color 0.18s ease,
      color 0.18s ease;
  }
  /* City links are quiet by default and FILL on hover instead of lifting: a
     whole card jumping under the cursor was the template tell, and nine of them
     jumping was this section's. The fill plus the red ink is the affordance. */
  .area-card[href]:hover {
    background: var(--color-surface-alt);
    color: var(--color-red);
  }
  /* Inset on purpose: the frame clips overflow, so a positive offset would cut
     the ring on the edge cells. Elsewhere on the site the ring stays at +3. */
  .area-card:focus-visible {
    outline: 3px solid var(--color-red);
    outline-offset: -3px;
  }
  .area-city {
    font-size: 1rem;
    line-height: 1.3;
  }

  /* The headquarters anchor. Home base, distinguished by scale, a filled surface
     and the badge — the most prominent cell, not a dimmed one. It has no page to
     link to, so it keeps no interactive affordance: no fill on hover, the cursor
     stays default, and the missing link reads as intentional. */
  .area-card.is-hq {
    background: var(--color-surface-alt);
    padding: 1.5rem 1.6rem;
  }
  .is-featured .area-city {
    font-size: 1.2rem;
  }
  .area-card.is-static,
  .area-card.is-static:hover {
    background: var(--color-surface-alt);
    color: var(--color-dark);
    cursor: default;
  }

  .area-badge {
    flex-shrink: 0;
    padding: 0.28rem 0.7rem;
    border-radius: 999px;
    background: var(--color-red);
    color: var(--color-white);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* Tablet holds three columns so the 3x3 stays intact; only below it does the
     directory collapse to a single column. Two columns are skipped on purpose:
     nine cities in two columns would always leave a trailing orphan. */
  @media (max-width: 640px) {
    .area-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
