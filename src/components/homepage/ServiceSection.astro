---
/**
 * ServiceSection.astro — a featured-services block for ONE service category.
 *
 * Used twice on the homepage (plumbing, then heating and cooling) and reusable
 * for any trade. The `emphasis` prop is what lets one call render heavier than
 * the other WITHOUT duplicating the component:
 *
 *   emphasis="primary"   → larger heading, 3-up card grid, tinted surface,
 *                          solid CTA button. Use for the company's main trade.
 *   emphasis="secondary" → smaller heading, denser grid, plain surface,
 *                          outlined CTA.
 *
 * Cards are passed in already resolved from the service data, so this component
 * never reaches into the service architecture itself and cannot link to a page
 * that does not exist.
 */
export interface ServiceCard {
  name: string;
  href: string;
  blurb: string;
}

interface Props {
  id: string;
  heading: string;
  intro: string;
  cards: ServiceCard[];
  ctaLabel: string;
  ctaHref: string;
  emphasis?: 'primary' | 'secondary';
}

const { id, heading, intro, cards, ctaLabel, ctaHref, emphasis = 'secondary' } = Astro.props;
const headingId = `${id}-heading`;
---

<section class:list={['service-section', emphasis]} aria-labelledby={headingId}>
  <div class="container">
    <header class="section-head">
      <h2 id={headingId}>{heading}</h2>
      <p class="section-intro">{intro}</p>
    </header>

    <ul class="card-grid">
      {
        cards.map((card) => (
          <li>
            <a class="service-card" href={card.href}>
              <h3>{card.name}</h3>
              <p>{card.blurb}</p>
              <span class="card-link" aria-hidden="true">
                Learn more
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    <div class="section-cta">
      <a class:list={['btn', emphasis === 'primary' ? 'btn-solid' : 'btn-outline']} href={ctaHref}>
        {ctaLabel}
      </a>
    </div>
  </div>
</section>

<style>
  .service-section {
    padding: var(--section-y) 0;
  }
  .service-section.primary {
    background: var(--color-surface-alt);
    border-bottom: 1px solid var(--color-border);
  }
  .service-section.secondary {
    background: var(--color-white);
  }

  .section-head {
    max-width: 62ch;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  h2 {
    margin: 0 0 1rem;
    text-wrap: balance;
  }
  /* The primary trade simply gets more visual weight than the secondary one. */
  .primary h2 {
    font-size: clamp(2.4rem, 4.2vw, 3.4rem);
  }
  .secondary h2 {
    font-size: clamp(2rem, 3.2vw, 2.6rem);
  }
  .section-intro {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.75;
    color: var(--color-muted);
  }

  .card-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
  }
  .primary .card-grid {
    grid-template-columns: repeat(3, 1fr);
  }
  .secondary .card-grid {
    grid-template-columns: repeat(4, 1fr);
  }

  .service-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.6rem;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.18s ease,
      box-shadow 0.18s ease,
      transform 0.18s ease;
  }
  .service-card:hover {
    border-color: var(--color-red);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .service-card:focus-visible {
    outline: 3px solid var(--color-red);
    outline-offset: 3px;
  }
  .service-card h3 {
    margin: 0 0 0.6rem;
    font-size: 1.5rem;
  }
  .service-card p {
    margin: 0 0 1.25rem;
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.65;
    flex: 1;
  }
  .card-link {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-red);
  }

  .section-cta {
    margin-top: clamp(2rem, 4vw, 2.75rem);
  }
  .btn {
    display: inline-block;
    padding: 0.95rem 1.75rem;
    border-radius: var(--radius-sm);
    font-weight: 600;
    text-decoration: none;
    border: 2px solid var(--color-red);
    transition:
      background-color 0.18s ease,
      color 0.18s ease;
  }
  .btn-solid {
    background: var(--color-red);
    color: var(--color-white);
  }
  .btn-solid:hover {
    background: var(--accent-dark);
    border-color: var(--accent-dark);
  }
  .btn-outline {
    background: transparent;
    color: var(--color-red);
  }
  .btn-outline:hover {
    background: var(--color-red);
    color: var(--color-white);
  }

  @media (max-width: 1000px) {
    .primary .card-grid,
    .secondary .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .primary .card-grid,
    .secondary .card-grid {
      grid-template-columns: 1fr;
    }
    .section-cta .btn {
      display: block;
      text-align: center;
    }
  }
</style>
