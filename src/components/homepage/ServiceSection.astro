---
/**
 * ServiceSection.astro — a featured-services block for ONE service category.
 *
 * Used twice on the homepage (plumbing, then heating and cooling) and reusable
 * for any trade.
 *
 * ONE CARD PRIMITIVE, TWO SECTIONS.
 * The card is identical in both calls: same type, padding, border, internal
 * rhythm, action row, focus ring and hover. Emphasis lives entirely at the
 * SECTION level, which is where it belongs. Previously the card itself changed
 * between the two, and the grids differed (3-up vs 4-up), so the same component
 * rendered cards 91px apart in width at 1440 and the two sections read as two
 * different templates. Now only the surface, the heading scale, the column count
 * and the CTA fill differ.
 *
 *   emphasis="primary"   → deeper surface, red accent rule, more vertical air,
 *                          3 columns, solid CTA. The company's main trade.
 *   emphasis="secondary" → white surface, 2 columns, outline CTA. Quieter, not
 *                          lesser: it is the same card, the same type, the same
 *                          everything except weight.
 *
 * Cards are passed in already resolved from the service data, so this component
 * never reaches into the service architecture itself and cannot link to a page
 * that does not exist.
 *
 * THE OPENING SPREAD (primary trade only).
 * The primary section opens like a magazine feature: the heading and intro sit
 * in a narrow left column beside a tall image plate, and the card grid runs
 * clean beneath the pair. That one photographic beat is what carries the hero's
 * cinematic language down into the content instead of dropping straight from a
 * full-bleed photo onto a flat wall of cards. The image is OPTIONAL and follows
 * the exact pattern the sibling sections already use (TrustSection, AboutSection):
 * a real photo when one exists, the branded BrandPanel plate when it does not, so
 * the layout is finished either way and dropping a photo in later shifts nothing.
 *
 * The SECONDARY trade never gets the spread. It keeps the plain stacked header it
 * has always had, so the two sections stay one framework with one difference in
 * weight, exactly as before. Nothing here changes the card primitive.
 */
import type { ImageAsset } from '../../config/images';
import ContentImage from '../content-pages/ContentImage.astro';

export interface ServiceCard {
  name: string;
  href: string;
  blurb: string;
}

interface Props {
  id: string;
  heading: string;
  intro: string;
  cards: ServiceCard[];
  ctaLabel: string;
  ctaHref: string;
  emphasis?: 'primary' | 'secondary';
  /**
   * The opening-spread plate for the primary trade. Real photography when it
   * exists, `null` to render the branded fallback. Ignored by the secondary
   * trade, which has no spread. Omitted entirely and the primary still renders
   * the branded plate, so the spread is never half-built.
   */
  image?: ImageAsset | null;
}

const {
  id,
  heading,
  intro,
  cards,
  ctaLabel,
  ctaHref,
  emphasis = 'secondary',
  image = null,
} = Astro.props;
const headingId = `${id}-heading`;
const hasSpread = emphasis === 'primary';
---

<section class:list={['service-section', emphasis]} aria-labelledby={headingId}>
  <div class="container">
    {
      hasSpread ? (
        <div class="section-masthead">
          <header class="section-head">
            {/* The accent rule on the primary trade, echoing the hero's eyebrow.
                It is decoration, so it is hidden from assistive technology. */}
            <span class="head-rule" aria-hidden="true" />
            <h2 id={headingId}>{heading}</h2>
            <p class="section-intro">{intro}</p>
          </header>
          <div class="masthead-media">
            <ContentImage asset={image} tone="light" ratio="4 / 3" fit="cover" />
          </div>
        </div>
      ) : (
        <header class="section-head">
          <h2 id={headingId}>{heading}</h2>
          <p class="section-intro">{intro}</p>
        </header>
      )
    }

    <ul class="card-grid">
      {
        cards.map((card) => (
          <li>
            <a class="service-card" href={card.href}>
              <h3>{card.name}</h3>
              <p>{card.blurb}</p>
              <span class="card-action" aria-hidden="true">
                Learn more
                <svg viewBox="0 0 16 16" width="14" height="14" focusable="false">
                  <path
                    d="M2 8h11M9 4l4 4-4 4"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    <div class="section-cta">
      <a class:list={['btn', emphasis === 'primary' ? 'btn-solid' : 'btn-outline']} href={ctaHref}>
        {ctaLabel}
      </a>
    </div>
  </div>
</section>

<style>
  .service-section {
    padding: var(--section-y) 0;
  }
  /* PRIMARY SURFACE. The brand black at 4.5% over white, not a new colour. The
     old --color-surface-alt (#f7f8f8) was so close to white that the primary
     band read as no band at all, so the emphasis was doing nothing. This is
     still restrained, but it is actually visible. The rules top and bottom are
     what turn the Plumbing / Trust / HVAC sequence into a rhythm rather than
     three hard cuts. */
  .service-section.primary {
    background-color: rgba(5, 7, 7, 0.045);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    /* The primary trade gets more air. Space is the cheapest premium signal. */
    padding: calc(var(--section-y) * 1.15) 0;
  }
  .service-section.secondary {
    background: var(--color-white);
  }

  .section-head {
    max-width: 62ch;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  /* THE OPENING SPREAD. An asymmetric two-column masthead: the title block in a
     narrower left column, the image plate wider on the right, the pair centred
     to each other so a short heading does not float at the top of a tall photo.
     The card grid follows underneath at full width. This is the whole premium
     move: one photographic beat between the hero and the index of cards. */
  .section-masthead {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  /* Inside the spread the title block carries no bottom margin (the masthead owns
     the gap to the grid) and takes a tighter measure so it reads as a column, not
     a full-width paragraph that happens to sit next to a picture. */
  .section-masthead .section-head {
    max-width: 46ch;
    margin-bottom: 0;
  }
  .masthead-media {
    width: 100%;
  }
  /* The red accent on the primary section, echoing the hero eyebrow. */
  .head-rule {
    display: block;
    width: 40px;
    height: 3px;
    border-radius: 2px;
    background: var(--color-red);
    margin-bottom: 1.25rem;
  }
  h2 {
    margin: 0 0 1rem;
    text-wrap: balance;
  }
  /* Cormorant stays for display type. Only the SCALE differs between the two. */
  .primary h2 {
    font-size: clamp(2.4rem, 4.2vw, 3.4rem);
  }
  .secondary h2 {
    font-size: clamp(2rem, 3.2vw, 2.6rem);
  }
  .section-intro {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.75;
    color: var(--color-muted);
  }

  /* ONE GRID RULE. Only the desktop column count differs: the primary trade
     gets 3 across, the secondary 2. Both fall to 2 then 1 on the same ladder,
     so neither can produce an orphan row: 6 divides by 3 and 2, and 4 divides
     by 2. */
  .card-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
  }
  .primary .card-grid {
    grid-template-columns: repeat(3, 1fr);
  }
  .secondary .card-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  /* ---------------------------------------------------------------------------
     THE CARD PRIMITIVE. Identical in both sections. Nothing below this comment
     is allowed to vary by emphasis.
     --------------------------------------------------------------------------- */
  .service-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.75rem;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }
  /* Restrained. The card no longer lifts on hover: a whole card jumping under
     the cursor is the template tell. The border, the shadow and the arrow carry
     the affordance instead. */
  .service-card:hover {
    border-color: var(--color-red);
    box-shadow: var(--shadow-md);
  }
  .service-card:focus-visible {
    outline: 3px solid var(--color-red);
    outline-offset: 3px;
  }

  /* Montserrat, not Cormorant. Cormorant is a high-contrast display serif and at
     card-title size its thin strokes go delicate, which is the opposite of what
     a plumbing card should feel like. The families are unchanged: Cormorant
     keeps the display sizes, Montserrat takes component-level titles where
     strength and readability matter more than flourish. */
  .service-card h3 {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.15rem;
    line-height: 1.35;
    letter-spacing: -0.005em;
    margin: 0 0 0.65rem;
    color: var(--color-dark);
  }
  .service-card p {
    margin: 0 0 1.5rem;
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.65;
    flex: 1;
  }

  /* The action row sits in a defined zone above a hairline, instead of floating
     at the bottom of the card. */
  .card-action {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-red);
  }
  .card-action svg {
    transition: transform 0.18s ease;
  }
  .service-card:hover .card-action svg {
    transform: translateX(3px);
  }

  /* The hover motion is decorative and must not be forced on anyone who has
     asked the OS for less of it. */
  @media (prefers-reduced-motion: reduce) {
    .service-card,
    .card-action svg {
      transition: none;
    }
    .service-card:hover .card-action svg {
      transform: none;
    }
  }

  .section-cta {
    margin-top: clamp(2rem, 4vw, 2.75rem);
  }
  .btn {
    display: inline-block;
    padding: 0.95rem 1.75rem;
    border-radius: var(--radius-sm);
    font-weight: 600;
    text-decoration: none;
    border: 2px solid var(--color-red);
    transition:
      background-color 0.18s ease,
      color 0.18s ease;
  }
  .btn-solid {
    background: var(--color-red);
    color: var(--color-white);
  }
  .btn-solid:hover {
    background: var(--accent-dark);
    border-color: var(--accent-dark);
  }
  .btn-outline {
    background: transparent;
    color: var(--color-red);
  }
  .btn-outline:hover {
    background: var(--color-red);
    color: var(--color-white);
  }

  /* The spread stacks before the grid does: once the title column would be
     squeezed narrower than its measure, the plate drops below the title rather
     than being crushed beside it. The title then relaxes back to a full measure. */
  @media (max-width: 900px) {
    .section-masthead {
      grid-template-columns: 1fr;
      gap: clamp(1.75rem, 4vw, 2.5rem);
    }
    .section-masthead .section-head {
      max-width: 62ch;
    }
  }

  /* The same ladder for both sections: 3-or-2 → 2 → 1. */
  @media (max-width: 1000px) {
    .primary .card-grid,
    .secondary .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .primary .card-grid,
    .secondary .card-grid {
      grid-template-columns: 1fr;
    }
    .section-cta .btn {
      display: block;
      text-align: center;
    }
  }
</style>
