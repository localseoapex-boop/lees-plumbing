---
/**
 * CausesSection.astro — "Common Causes of ..." / "Reasons to Consider ...".
 *
 * Structurally a sibling of SignsSection, but rendered as a two-column
 * definition list rather than a card grid so the two sections do not read as the
 * same block twice in a row.
 *
 * The heading is a prop for the same reason it is on SignsSection: "Common
 * Causes of Water Heater Problems" is right for a repair page, and nonsense on an
 * installation page, which wants "Reasons to Consider Water Heater Installation".
 * Repair language does not get forced onto installation pages.
 *
 * White tone, and a red rule above the heading, so it shares the section
 * signature with SignsSection and the trust band. Its left-rule list keeps it
 * visually distinct from SignsSection's top-rule divided list, so the two do not
 * read as the same block twice.
 */
import type { ContentPoint } from '../../data/service-content';

interface Props {
  id: string;
  heading: string;
  items: ContentPoint[];
}

const { id, heading, items } = Astro.props;
const headingId = `${id}-heading`;
---

<section class="causes" aria-labelledby={headingId}>
  <div class="container">
    <span class="head-rule" aria-hidden="true"></span>
    <h2 id={headingId}>{heading}</h2>

    <ul class="cause-list">
      {
        items.map((item) => (
          <li class="cause">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .causes {
    background: var(--color-surface);
    padding: var(--section-y) 0;
  }
  .head-rule {
    display: block;
    width: 40px;
    height: 3px;
    border-radius: 2px;
    background: var(--color-red);
    margin-bottom: 1.25rem;
  }
  h2 {
    font-size: clamp(2rem, 3.4vw, 2.75rem);
    margin: 0 0 clamp(1.5rem, 3vw, 2.25rem);
    max-width: 26ch;
    text-wrap: balance;
  }

  .cause-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem 2.5rem;
  }
  .cause {
    padding-left: 1.1rem;
    border-left: 3px solid var(--color-red);
  }
  .cause h3 {
    font-size: 1.15rem;
    margin: 0 0 0.4rem;
  }
  .cause p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  @media (max-width: 760px) {
    .cause-list {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }
</style>
