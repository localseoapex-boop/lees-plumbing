---
/**
 * RelatedServicesSection.astro — contextual sibling links plus the parent hub.
 *
 * Sub-service pages only. The links come from the curated `related` list in
 * data/service-content.ts, which is validated at build time to contain only real
 * sibling slugs and never the page's own slug. Nothing is backfilled to pad the
 * section, because a link that exists only to fill a grid is not a related
 * service, it is noise.
 *
 * The parent hub is always the last card and is marked as such, so the block
 * doubles as the route back up the hierarchy.
 */
export interface RelatedLink {
  name: string;
  description: string;
  href: string;
  /** True for the parent category hub, which is styled as the way back up. */
  isParent?: boolean;
}

interface Props {
  id: string;
  heading: string;
  links: RelatedLink[];
}

const { id, heading, links } = Astro.props;
const headingId = `${id}-heading`;
---

<section class="related" aria-labelledby={headingId}>
  <div class="container">
    <h2 id={headingId}>{heading}</h2>

    <ul class="related-grid">
      {
        links.map((link) => (
          <li>
            <a class:list={['related-card', link.isParent && 'is-parent']} href={link.href}>
              {link.isParent && <span class="related-kicker">All Services</span>}
              <span class="related-name">{link.name}</span>
              <span class="related-desc">{link.description}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .related {
    background: var(--color-surface-alt);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: var(--section-y) 0;
  }
  h2 {
    font-size: clamp(2rem, 3.4vw, 2.75rem);
    margin: 0 0 clamp(1.75rem, 3.5vw, 2.5rem);
    text-wrap: balance;
  }

  .related-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
  }
  .related-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.35rem 1.5rem;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    transition:
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }
  .related-card:hover {
    border-color: var(--color-red);
    box-shadow: var(--shadow-md);
  }
  .related-card:focus-visible {
    outline: 3px solid var(--color-red);
    outline-offset: 3px;
  }
  .related-card.is-parent {
    background: var(--color-dark);
    border-color: var(--color-dark);
  }

  .related-kicker {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    color: #f0a3a3;
    margin-bottom: 0.4rem;
  }
  .related-name {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 0.35rem;
  }
  .related-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-muted);
  }
  .related-card.is-parent .related-name {
    color: var(--color-white);
  }
  .related-card.is-parent .related-desc {
    color: #b3b7b7;
  }

  @media (max-width: 560px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
