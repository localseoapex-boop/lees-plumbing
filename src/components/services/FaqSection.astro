---
/**
 * FaqSection.astro — the ONE shared FAQ accordion for every page family that
 * renders FAQs (the plumbing hub, all sub-service pages, and all city pages).
 *
 * NATIVE, NO JAVASCRIPT. Each question is a <details>/<summary>, so the open and
 * closed state is real browser state exposed to assistive technology, it works
 * with JavaScript disabled, it is keyboard operable, and there is no hydration
 * boundary. There is deliberately no accordion script anywhere: opening one
 * question never closes another, the page never auto-scrolls, and nothing opens
 * on load. Multiple questions may be open at once.
 *
 * NO FAQPage SCHEMA is emitted, here or in the layouts, and that is unchanged by
 * this redesign. The site's schema strategy is a LocalBusiness graph plus one
 * Service node per page; the visible questions and answers are complete on their
 * own. All answer text stays in the server-rendered HTML inside the <details>, so
 * it is crawlable and never hidden behind client-only rendering.
 *
 * STATE WITHOUT COLOUR. The + / - icon changes SHAPE, not just colour, so the
 * open/closed state is legible without relying on the red accent alone.
 *
 * Renders the section's <h2>. Questions live inside <summary> and are NOT
 * headings, so the document outline keeps exactly one heading for this section,
 * the same as the list it replaces.
 */
import type { FaqItem } from '../../data/service-content';

interface Props {
  id: string;
  heading: string;
  items: FaqItem[];
}

const { id, heading, items } = Astro.props;
const headingId = `${id}-heading`;
---

<section class="faq" aria-labelledby={headingId}>
  <div class="container">
    <span class="head-rule" aria-hidden="true"></span>
    <h2 id={headingId}>{heading}</h2>

    <div class="faq-list">
      {
        items.map((item) => (
          <details class="faq-item">
            <summary class="faq-question">
              <span class="faq-q-text">{item.question}</span>
              <span class="faq-icon" aria-hidden="true" />
            </summary>
            <div class="faq-answer">
              <p>{item.answer}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq {
    background: var(--color-surface);
    padding: var(--section-y) 0;
  }
  /* The shared red section signature, matching the trust band and the editorial
     sections, so the FAQ reads as part of the same system and is set apart from
     the section above it. */
  .head-rule {
    display: block;
    width: 40px;
    height: 3px;
    border-radius: 2px;
    background: var(--color-red);
    margin-bottom: 1.25rem;
  }
  h2 {
    font-size: clamp(2rem, 3.4vw, 2.75rem);
    margin: 0 0 clamp(1.5rem, 3vw, 2.25rem);
    text-wrap: balance;
  }

  /* A hairline-divided list, top and bottom rule enclosing it, no cards and no
     shadow. The list is capped at a readable width and left-aligned under the
     heading, the same as the other editorial sections. */
  .faq-list {
    max-width: 780px;
  }
  .faq-item {
    border-top: 1px solid var(--color-border);
  }
  .faq-item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  /* The whole question row is the control. align-items:flex-start keeps the icon
     pinned to the FIRST line of a question that wraps to several lines. */
  .faq-question {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 44px;
    padding: 1.25rem 0;
    cursor: pointer;
    /* Remove the native disclosure triangle in every engine. */
    list-style: none;
  }
  .faq-question::-webkit-details-marker {
    display: none;
  }
  .faq-q-text {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.08rem;
    line-height: 1.4;
    color: var(--color-dark);
  }
  @media (hover: hover) {
    .faq-question:hover .faq-q-text {
      color: var(--color-red);
    }
  }
  /* Strong, unclipped keyboard focus. There is no overflow-clipping container, so
     the ring is never cut off, including on the first and last rows. */
  .faq-question:focus-visible {
    outline: 3px solid var(--color-red);
    outline-offset: 3px;
    border-radius: 2px;
  }

  /* CSS plus/minus. Two red bars: the horizontal one is always shown, the
     vertical one is removed when the item is open, so + becomes -. The shape
     change is the state cue; the colour is secondary. */
  .faq-icon {
    position: relative;
    flex: none;
    width: 20px;
    height: 20px;
    /* Nudge onto the optical centre of the first question line. */
    margin-top: 0.1rem;
  }
  .faq-icon::before,
  .faq-icon::after {
    content: '';
    position: absolute;
    background: var(--color-red);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }
  .faq-icon::before {
    top: 50%;
    left: 0;
    right: 0;
    height: 2px;
    transform: translateY(-50%);
  }
  .faq-icon::after {
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    transform: translateX(-50%);
  }
  .faq-item[open] .faq-icon::after {
    opacity: 0;
    transform: translateX(-50%) rotate(90deg);
  }

  /* Answer. Instant show/hide from the native element, so there is no height
     animation and nothing can be clipped. Capped at a readable measure. */
  .faq-answer {
    padding: 0 0 1.5rem;
    max-width: 68ch;
  }
  .faq-answer p {
    margin: 0;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-icon::before,
    .faq-icon::after {
      transition: none;
    }
  }

  /* On paper an accordion makes no sense: reveal every answer so a printed page
     is complete, whether or not the item was open on screen. Two hiding
     mechanisms are covered, since a closed <details> hides its content with
     display:none in older engines and with content-visibility on
     ::details-content in newer ones. The ::details-content rule is simply ignored
     by engines that do not understand it, so nothing breaks. The +/- icon has no
     meaning in print, so it is dropped. This block affects print only and leaves
     the on-screen behaviour untouched. */
  @media print {
    .faq-item > *:not(summary) {
      display: block !important;
    }
    .faq-item::details-content {
      content-visibility: visible !important;
    }
    .faq-icon {
      display: none;
    }
  }
</style>
