---
/**
 * ServiceHero.astro — the conversion hero for hub AND sub-service pages (and,
 * per direction, the city pages, which reuse this same component).
 *
 * One component serves every tier. The difference between the heroes is entirely
 * in the props (heading, lede, and where the secondary CTA jumps to), not in the
 * markup, so there is a single hero to keep in sync rather than one per page type.
 *
 * THE RIGHT COLUMN is the coded coupon card (HeroOfferCard). It replaced the old
 * "Speak With Us" contact panel: the offer is a real, confirmed coupon, so the
 * hero now leads with savings rather than a restatement of the phone number. All
 * offer copy comes from the shared OFFER source, so it is never duplicated here.
 *
 * The standalone phone-number row that used to sit under the CTA buttons is gone
 * too: it duplicated the "Call to Schedule" button beside it. The phone CTA
 * itself stays as the primary action.
 *
 * Renders the page's single H1. Nothing else on these pages emits one.
 */
import type { ImageAsset } from '../../config/images';
import HeroOfferCard from './HeroOfferCard.astro';

interface Props {
  eyebrow: string;
  /** The page's one and only H1. */
  heading: string;
  lede: string;
  /** Powers the primary "Call to Schedule" CTA (tel: link). */
  phone: string;
  /** In-page anchor, e.g. "#services" or "#about-this-service". */
  secondaryCtaLabel: string;
  secondaryCtaHref: string;
  /**
   * Optional contextual background photo, config-driven per page. Null/omitted
   * renders the flat dark hero unchanged, so any page without a photo is exactly
   * as before. It is an AI illustration of the trade: DECORATIVE (empty alt), no
   * branding, no claim (see SERVICE_HERO_IMAGES in config/images.ts). Rendered
   * with the homepage hero's technique: a real <img> behind the content with
   * fetchpriority high (the LCP element) and a scrim dimensioned for the worst
   * case so white copy stays legible over artwork nobody has previewed.
   */
  heroImage?: ImageAsset | null;
}

const {
  eyebrow,
  heading,
  lede,
  phone,
  secondaryCtaLabel,
  secondaryCtaHref,
  heroImage = null,
} = Astro.props;
---

<section class:list={['hero', { 'has-image': heroImage }]}>
  {
    heroImage && (
      <Fragment>
        <img
          class="hero-bg"
          src={heroImage.src}
          alt=""
          width={heroImage.width}
          height={heroImage.height}
          fetchpriority="high"
          loading="eager"
          decoding="async"
        />
        <div class="hero-scrim" aria-hidden="true" />
      </Fragment>
    )
  }
  <div class="container hero-inner">
    <div class="hero-copy">
      <p class="eyebrow-light">{eyebrow}</p>
      <h1>{heading}</h1>
      <p class="hero-lede">{lede}</p>

      <div class="hero-actions">
        <a class="btn-primary" href={`tel:${phone}`}>Call to Schedule</a>
        <a class="btn-ghost" href={secondaryCtaHref}>{secondaryCtaLabel}</a>
      </div>
    </div>

    <HeroOfferCard />
  </div>
</section>

<style>
  .hero {
    /* The fallback AND the safety net: with no image, or if the file 404s, the
       white text sits on flat brand black exactly as before. */
    background: var(--color-dark);
    color: var(--color-white);
    padding: clamp(2.5rem, 6vw, 4.5rem) 0 clamp(3rem, 6vw, 4.5rem);
  }
  /* Only the photographic variant needs a stacking context and clipping. */
  .hero.has-image {
    position: relative;
    isolation: isolate;
    overflow: hidden;
  }
  /* Out of flow, so it can never cause layout shift. Behaves like a background
     but loads like a priority image (it is the LCP element on these pages). */
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 60% 45%;
    z-index: -2;
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    /* Copy sits on the LEFT and the solid contact panel on the RIGHT, so the
       scrim is heaviest on the left where the text lives and lifts toward the
       right where the photo can breathe behind and around the panel. All layers
       are the brand black at varying alpha, so no new colour enters. Dimensioned
       against the worst case: even over a pure-white photo the left zone stays
       near #1a1c1c, which keeps the white lede above 12:1. */
    background-image: linear-gradient(
      90deg,
      rgba(5, 7, 7, 0.93) 0%,
      rgba(5, 7, 7, 0.86) 38%,
      rgba(5, 7, 7, 0.58) 72%,
      rgba(5, 7, 7, 0.46) 100%
    );
    background-color: rgba(5, 7, 7, 0.42);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: center;
  }
  .hero.has-image .hero-inner {
    position: relative;
    z-index: 1;
  }

  .eyebrow-light {
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    font-weight: 700;
    color: #f0a3a3;
  }
  h1 {
    color: var(--color-white);
    font-size: clamp(2.25rem, 4.4vw, 3.5rem);
    margin: 0 0 1rem;
    text-wrap: balance;
  }
  .hero-lede {
    margin: 0;
    max-width: 56ch;
    color: #c9cccc;
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.75rem;
  }
  .btn-primary,
  .btn-ghost {
    display: inline-block;
    padding: 0.9rem 1.6rem;
    border-radius: var(--radius-sm);
    font-weight: 600;
    text-decoration: none;
    transition:
      background-color 0.18s ease,
      color 0.18s ease,
      border-color 0.18s ease;
  }
  .btn-primary {
    background: var(--color-red);
    color: var(--color-white);
    border: 2px solid var(--color-red);
  }
  .btn-primary:hover {
    background: var(--accent-dark);
    border-color: var(--accent-dark);
  }
  .btn-ghost {
    border: 2px solid #3a4040;
    color: var(--color-white);
  }
  .btn-ghost:hover {
    border-color: var(--color-white);
  }
  .btn-primary:focus-visible,
  .btn-ghost:focus-visible {
    outline: 3px solid var(--color-white);
    outline-offset: 3px;
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      align-items: stretch;
    }
    /* Stacked: copy and the panel now span the full width, so the horizontal
       falloff is meaningless. The scrim runs vertically and stays heavy through
       the whole column, since content covers the frame; the photo reads as a
       quiet warm texture rather than a subject. */
    .hero.has-image .hero-scrim {
      background-image: linear-gradient(
        180deg,
        rgba(5, 7, 7, 0.9) 0%,
        rgba(5, 7, 7, 0.85) 55%,
        rgba(5, 7, 7, 0.82) 100%
      );
      background-color: rgba(5, 7, 7, 0.5);
    }
    .hero-bg {
      object-position: 60% 40%;
    }
  }
  @media (max-width: 480px) {
    .hero-actions {
      display: grid;
      grid-template-columns: 1fr;
    }
    .btn-primary,
    .btn-ghost {
      text-align: center;
    }
  }
</style>
