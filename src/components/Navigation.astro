---
/**
 * Navigation.astro — site header + primary nav, with one dropdown.
 *
 * Links come from NAV_LINKS so the menu is edited in one place. An entry with
 * `children` renders as a dropdown; everything else renders as a plain link.
 *
 * THE DROPDOWN, and why it is built this way:
 *
 * The trigger is a real <button>, not a link. A link that also opens a menu is
 * the classic broken pattern: keyboard users activate it and get navigated away
 * instead of opening the menu. "About Us" is a menu, not a page, so it is a
 * button and it has no href.
 *
 * Opening is CSS-FIRST and works with no JavaScript at all:
 *   - :has(:focus-visible) opens it when a KEYBOARD user tabs in. Not
 *     :focus-within, which would also fire on a tap and fight the tap-to-toggle
 *     below, leaving touch users unable to open the menu at all.
 *   - :hover opens it on hover-capable devices only, gated behind a media query
 *     so a touch device never opens the menu from a stray hover
 *   - [data-open='true'] opens it on click / tap, and [data-open='false'] force
 *     closes it, beating both of the above when the user explicitly dismissed it
 *
 * The script is 30 lines and does only what CSS cannot: toggle on click (touch
 * and mouse), close on Escape and return focus to the trigger, close on an
 * outside click, and keep aria-expanded truthful while the menu is open by
 * hover. Without that last part the button would announce "collapsed" to a
 * screen reader while the menu was visibly open. No library, no framework.
 *
 * If the script fails to load, hover and keyboard focus still open the menu and
 * every link inside it is still reachable. The nav degrades, it does not break.
 */
import { SITE, BUSINESS, NAV_LINKS, isNavGroup } from '../config/site';
import BrandLogo from './BrandLogo.astro';

const currentPath = Astro.url.pathname;
const normalize = (path: string) => (path.length > 1 ? path.replace(/\/$/, '') : path);

const isActive = (href: string) => {
  const path = normalize(currentPath);
  const target = normalize(href);
  if (target === '/') return path === '/';
  return path === target || path.startsWith(`${target}/`);
};

/** A group is "current" when the open page is one of its children. */
const groupHasActiveChild = (children: readonly { href: string }[]) =>
  children.some((child) => isActive(child.href));
---

<header class="site-header" data-site-header>
  <nav class="nav" aria-label="Primary">
    <a href="/" class="brand" aria-label={`${SITE.name} home`}>
      <BrandLogo tone="light" />
    </a>

    {/*
      The menu button is rendered ALWAYS but is invisible until the script marks
      the header as enhanced. That is what makes the no-JavaScript fallback safe:
      a button that cannot work is a button nobody can see. See the header
      comment for the full reasoning.
    */}
    <button
      type="button"
      class="nav-toggle"
      id="nav-toggle"
      aria-expanded="false"
      aria-controls="primary-nav"
      data-nav-toggle
    >
      <span class="sr-only">Menu</span>
      <span class="toggle-bars" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>

    <ul class="nav-links" id="primary-nav">
      {
        NAV_LINKS.map((item, i) =>
          isNavGroup(item) ? (
            <li class="nav-group" data-nav-group>
              <button
                type="button"
                class="nav-trigger"
                id={`nav-trigger-${i}`}
                aria-expanded="false"
                aria-controls={`nav-menu-${i}`}
                data-nav-trigger
                data-current={groupHasActiveChild(item.children) ? 'true' : undefined}
              >
                {item.label}
                <svg
                  class="nav-caret"
                  width="10"
                  height="6"
                  viewBox="0 0 10 6"
                  aria-hidden="true"
                  focusable="false"
                >
                  <path
                    d="M1 1l4 4 4-4"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </button>

              <ul class="nav-menu" id={`nav-menu-${i}`} aria-labelledby={`nav-trigger-${i}`}>
                {item.children.map((child) => (
                  <li>
                    <a href={child.href} aria-current={isActive(child.href) ? 'page' : undefined}>
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          ) : (
            <li>
              <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ),
        )
      }
    </ul>

    <a class="cta" href={`tel:${BUSINESS.phone}`}>Call {BUSINESS.phoneDisplay}</a>
  </nav>
</header>

<script>
  // ---------------------------------------------------------------------------
  // MOBILE MENU (the collapsed disclosure below 860px)
  //
  // The FIRST thing this does is mark the header as enhanced. Until that happens
  // the CSS keeps the toggle button hidden and the link list visible, so a
  // visitor whose JavaScript never ran sees the full navigation rather than a
  // menu button that does nothing. The enhanced state is therefore only ever
  // entered by a browser that is definitely running the code that powers it.
  //
  // This is a DISCLOSURE, not a modal. The menu expands in flow and pushes the
  // page down: nothing is covering the content, so there is deliberately no
  // focus trap, no scroll lock, and no aria-modal. Trapping focus here would
  // actually be wrong, because the page behind is not inert.
  // ---------------------------------------------------------------------------
  const header = document.querySelector<HTMLElement>('[data-site-header]');
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');

  if (header && toggle) {
    header.dataset.enhanced = 'true';

    const setMenu = (open: boolean) => {
      header.dataset.menuOpen = String(open);
      toggle.setAttribute('aria-expanded', String(open));
    };

    toggle.addEventListener('click', () => {
      setMenu(header.dataset.menuOpen !== 'true');
    });

    // Escape closes and hands focus back to the button the user opened it with.
    header.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && header.dataset.menuOpen === 'true') {
        setMenu(false);
        toggle.focus();
      }
    });

    // A tap or click anywhere outside the header dismisses the menu.
    document.addEventListener('click', (event) => {
      if (header.dataset.menuOpen !== 'true') return;
      if (!header.contains(event.target as Node)) setMenu(false);
    });
  }

  // ---------------------------------------------------------------------------
  // ABOUT DROPDOWN. Unchanged. It works identically inside the mobile menu,
  // where it is a nested disclosure with its own button and its own aria state.
  // ---------------------------------------------------------------------------
  const groups = document.querySelectorAll<HTMLElement>('[data-nav-group]');

  groups.forEach((group) => {
    const trigger = group.querySelector<HTMLButtonElement>('[data-nav-trigger]');
    if (!trigger) return;

    const setOpen = (open: boolean) => {
      group.dataset.open = String(open);
      trigger.setAttribute('aria-expanded', String(open));
    };

    const canHover = () => window.matchMedia('(hover: hover) and (pointer: fine)').matches;

    trigger.addEventListener('click', () => {
      // On a hovering pointer the menu is ALREADY open just from the cursor
      // being here. Toggling on click would snap it shut under the user's mouse
      // the instant they clicked the thing they were trying to open, so a click
      // on an already-hover-opened menu does nothing. Moving the pointer away
      // closes it, which is what a mouse user expects.
      if (canHover() && group.matches(':hover') && group.dataset.open === 'true') return;
      setOpen(group.dataset.open !== 'true');
    });

    // Keep aria-expanded honest while the menu is open by hover or by focus, so
    // a screen reader is never told "collapsed" about a menu that is plainly
    // visible. These mirror the :hover and :has(:focus-visible) rules in the CSS.
    group.addEventListener('mouseenter', () => {
      if (canHover()) setOpen(true);
    });
    group.addEventListener('mouseleave', () => {
      if (canHover()) setOpen(false);
    });
    // Open on KEYBOARD focus only. The :focus-visible test is what makes this
    // safe: a tap also focuses the button, and if we opened on any focus at all
    // then the click that follows the tap would toggle the menu straight back
    // shut and a touch user could never open it. :focus-visible does not match
    // a touch or mouse focus, so this fires for the keyboard and nothing else.
    group.addEventListener('focusin', () => {
      if (trigger.matches(':focus-visible')) setOpen(true);
    });

    // Escape closes and puts focus back where the user left it.
    group.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && group.dataset.open === 'true') {
        setOpen(false);
        trigger.focus();
      }
    });

    // Tabbing out of the group closes it.
    group.addEventListener('focusout', (event) => {
      if (!group.contains(event.relatedTarget as Node)) setOpen(false);
    });

    // A tap or click anywhere else closes it. This is what makes the menu
    // dismissible on touch, where there is no "mouse leave".
    document.addEventListener('click', (event) => {
      if (!group.contains(event.target as Node)) setOpen(false);
    });
  });
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-white);
    /* The dropdown escapes the header, so the header must sit above the page. */
    position: relative;
    z-index: 20;
  }

  /* The menu button does not exist until the script says so. Without JavaScript
     it stays hidden and the link list stays visible, so nothing is unreachable
     and no dead control is ever shown. */
  .nav-toggle {
    display: none;
  }
  .nav {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  /* The brand is now a logo lockup, not a text node. It is sized through the two
     inherited custom properties BrandLogo reads, which is what lets the media
     queries below shrink it on narrow phones. */
  .brand {
    --brand-mark-height: 30px;
    --brand-word-size: 1.5rem;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    white-space: nowrap;
  }
  .brand:focus-visible {
    outline: 2px solid var(--color-red);
    outline-offset: 4px;
    border-radius: 2px;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    list-style: none;
    margin: 0 0 0 auto;
    padding: 0;
  }
  .nav-links > li {
    position: relative;
  }
  .nav-links a,
  .nav-trigger {
    color: var(--color-dark);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    /* The logo lockup is wider than the old text brand, and without this the
       flex line shrank the links until their labels wrapped: "Heating & /
       Cooling" over two lines at 1440. A nav label is an atom and must never
       break. There is room for all seven on one line; they just needed to be
       told not to fold. */
    white-space: nowrap;
  }
  .nav-links > li > a:hover,
  .nav-links > li > a[aria-current='page'] {
    color: var(--color-red);
  }

  /* Trigger: a button styled to sit flush with the links beside it. */
  .nav-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: none;
    border: 0;
    padding: 0;
    font-family: inherit;
    cursor: pointer;
    line-height: inherit;
  }
  .nav-trigger:hover,
  .nav-trigger[data-current='true'] {
    color: var(--color-red);
  }
  .nav-trigger:focus-visible,
  .nav-links a:focus-visible {
    outline: 2px solid var(--color-red);
    outline-offset: 3px;
    border-radius: 2px;
  }
  .nav-caret {
    transition: transform 0.18s ease;
  }
  .nav-group[data-open='true'] .nav-caret {
    transform: rotate(180deg);
  }

  /* The menu. Hidden by default, revealed by the three conditions below. */
  .nav-menu {
    position: absolute;
    top: calc(100% + 0.6rem);
    left: 0;
    z-index: 30;
    min-width: 260px;
    margin: 0;
    padding: 0.4rem;
    list-style: none;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);

    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition:
      opacity 0.16s ease,
      transform 0.16s ease,
      visibility 0.16s;
  }
  /* A hover bridge across the gap, so the menu does not snap shut when the
     pointer travels from the trigger down to the first item. */
  .nav-group::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 0.6rem;
  }

  /* 1. clicked or tapped open. 2. a KEYBOARD user has tabbed inside.
     :has(:focus-visible), not :focus-within, is deliberate. A tap focuses the
     button too, and :focus-within would therefore open the menu on tap, only for
     the click that follows the tap to toggle it shut again. :focus-visible
     matches keyboard focus and not touch focus, which is exactly the
     distinction this menu needs. It is also the no-JavaScript keyboard path. */
  .nav-group[data-open='true'] > .nav-menu,
  .nav-group:has(:focus-visible) > .nav-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  /* 3. hovered, but ONLY on devices that really have a hovering pointer. */
  @media (hover: hover) and (pointer: fine) {
    .nav-group:hover > .nav-menu {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
  }

  /* An EXPLICIT close beats hover and focus-within.
     Without this, clicking the trigger to dismiss a menu that hover had already
     opened would set aria-expanded="false" while :hover kept the menu plainly
     visible: the button would announce "collapsed" about an open menu, which is
     worse than having no aria at all. This rule is last so it wins the cascade
     at equal specificity, which keeps the visible state and the announced state
     telling the same story. */
  .nav-group[data-open='false'] > .nav-menu {
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
  }

  .nav-menu a {
    display: block;
    padding: 0.6rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.925rem;
    line-height: 1.45;
  }
  .nav-menu a:hover {
    background: var(--color-surface-alt);
    color: var(--color-red);
  }
  .nav-menu a[aria-current='page'] {
    color: var(--color-red);
    font-weight: 600;
  }

  .cta {
    background: var(--color-red);
    color: var(--color-white);
    text-decoration: none;
    padding: 0.5rem 0.9rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .cta:hover {
    background: var(--accent-dark);
  }

  /* Below the desktop breakpoint the nav becomes a COLLAPSED DISCLOSURE.
     The links move to their own full-width row and the dropdown stops being a
     floating panel: it expands INLINE. A floating panel anchored to a wrapped
     row is unusable on a narrow screen. */
  /* The collapse breakpoint is 1080px, not 860px.
     The logo lockup is wider than the text brand it replaced, and the seven nav
     labels must not wrap (a nav label is an atom). Between 861 and ~1080 the
     brand, the seven links and the call button no longer fit on one line, so the
     old 860 breakpoint left the header overflowing the viewport. Collapsing at
     the width where the desktop nav actually stops fitting is the honest fix:
     tablets get the hamburger, which is where they were heading anyway. */
  @media (max-width: 1080px) {
    .nav {
      flex-wrap: wrap;
      gap: 0.75rem;
      /* Brand on the left, then the call CTA and the menu button pinned right. */
      justify-content: space-between;
    }

    /* The hamburger. 44x44 is the minimum comfortable touch target, and the
       button is sized to it regardless of how small the glyph inside it is. */
    [data-enhanced] .nav-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      flex: none;
      padding: 0;
      background: none;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
      color: var(--color-dark);
      cursor: pointer;
      order: 3;
    }
    .nav-toggle:hover {
      border-color: var(--color-dark);
    }
    .nav-toggle:focus-visible {
      outline: 2px solid var(--color-red);
      outline-offset: 3px;
    }
    .toggle-bars {
      display: grid;
      gap: 4px;
      width: 20px;
    }
    .toggle-bars span {
      display: block;
      height: 2px;
      width: 100%;
      border-radius: 2px;
      background: currentColor;
      transition:
        transform 0.18s ease,
        opacity 0.18s ease;
    }
    /* Bars fold into an X, so the control shows its own state and does not rely
       on the label alone. */
    [data-menu-open='true'] .toggle-bars span:nth-child(1) {
      transform: translateY(6px) rotate(45deg);
    }
    [data-menu-open='true'] .toggle-bars span:nth-child(2) {
      opacity: 0;
    }
    [data-menu-open='true'] .toggle-bars span:nth-child(3) {
      transform: translateY(-6px) rotate(-45deg);
    }

    .nav-links {
      margin-left: 0;
      order: 4;
      width: 100%;
      flex-wrap: wrap;
      gap: 0.75rem 1.1rem;
    }
    .nav-links > li {
      position: static;
    }

    /* THE COLLAPSE. Everything below is scoped to the ENHANCED state.
       If the script never ran, the nav keeps exactly the behaviour it has today:
       a wrapped row of links, all reachable. It is bulky, but it is whole, and
       nothing in it is a control that cannot work.
       Scoping matters: an un-enhanced visitor given the STACKED layout would get
       a 563px header, which is worse than the 231px they have now. The stacked
       list is only correct when it can actually be collapsed. */
    [data-enhanced] .nav-links {
      display: none;
      flex-direction: column;
      align-items: stretch;
      flex-wrap: nowrap;
      gap: 0;
      padding-top: 0.25rem;
    }
    [data-enhanced][data-menu-open='true'] .nav-links {
      display: flex;
    }
    [data-enhanced] .nav-links > li {
      border-top: 1px solid var(--color-border);
    }
    [data-enhanced] .nav-links > li > a,
    [data-enhanced] .nav-trigger {
      display: flex;
      width: 100%;
      padding: 0.9rem 0.25rem;
      font-size: 1rem;
    }
    [data-enhanced] .nav-trigger {
      justify-content: space-between;
    }

    /* The call action stays in the header bar at ALL times, menu open or shut. A
       homeowner with a burst pipe must never have to open a menu to find the
       phone number. */
    .cta {
      order: 2;
      margin-left: auto;
      margin-right: 0.6rem;
    }

    .nav-group {
      width: 100%;
    }
    .nav-menu {
      position: static;
      min-width: 0;
      margin-top: 0;
      margin-bottom: 0.5rem;
      padding: 0 0 0 0.75rem;
      border: 0;
      border-left: 2px solid var(--color-border);
      border-radius: 0;
      box-shadow: none;
      transform: none;
      /* Collapse the box entirely when closed, so it takes no vertical space. */
      display: none;
    }

    /* NO-JAVASCRIPT: the About sub-links are shown expanded.
       Without this they would be unreachable on a phone with JS disabled, since
       the panel opens on :hover or :has(:focus-visible) and NEITHER matches a
       tap. That gap exists in the current shipped nav; this closes it. */
    .site-header:not([data-enhanced]) .nav-menu {
      display: block;
    }
    .site-header:not([data-enhanced]) .nav-caret {
      display: none;
    }

    .nav-group[data-open='true'] > .nav-menu,
    .nav-group:has(:focus-visible) > .nav-menu {
      display: block;
      transform: none;
    }
    /* Same explicit-close override as on desktop. */
    .nav-group[data-open='false'] > .nav-menu {
      display: none;
    }
    .nav-group::after {
      display: none;
    }
  }

  /* On the narrowest phones the brand, the call button and the menu button have
     to share one row. The BRAND gives up the space, not the phone number: the
     call action is the conversion and it keeps its full label. */
  @media (max-width: 480px) {
    .nav {
      padding: 0.6rem 1rem;
      gap: 0.5rem;
    }
    /* The lockup shrinks through the custom properties BrandLogo reads. A
       font-size here would no longer reach the wordmark, which sets its own. */
    .brand {
      --brand-mark-height: 26px;
      --brand-word-size: 1.2rem;
    }
    .cta {
      padding: 0.5rem 0.7rem;
      font-size: 0.85rem;
      margin-right: 0.4rem;
    }
  }

  /* 320px, the narrowest phone still in real use. Without this tier the three
     header controls no longer fit on one line and the bar wraps to two rows,
     which is exactly the disease this change is curing. The call button keeps
     its full label; the brand and the padding give up the millimetres. */
  @media (max-width: 360px) {
    .nav {
      padding: 0.6rem 0.5rem;
      gap: 0.3rem;
    }
    /* The lockup costs ~26px of width over the old text-only brand, which was
       enough to push the three header controls past the 296px available at 320
       and wrap the bar back to two rows. The mark and the wordmark both give up
       a little here so the bar stays on one line. */
    .brand {
      --brand-mark-height: 20px;
      --brand-word-size: 0.95rem;
    }
    .cta {
      padding: 0.4rem 0.5rem;
      font-size: 0.75rem;
      margin-right: 0.15rem;
    }
  }
</style>
