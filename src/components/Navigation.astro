---
/**
 * Navigation.astro — site header + primary nav.
 *
 * Pulls links from NAV_LINKS so the menu is edited in one place. Highlights the
 * active link by matching the current path against each href exactly or as a
 * path prefix — the nav now links directly to individual service categories, so
 * a coarse "first path segment" match would light up both service links at once.
 * A prominent "Call" CTA is standard for home-service sites where phone calls
 * are the main conversion.
 */
import { SITE, BUSINESS, NAV_LINKS } from '../config/site';

const currentPath = Astro.url.pathname;
const normalize = (path: string) => (path.length > 1 ? path.replace(/\/$/, '') : path);

const isActive = (href: string) => {
  const path = normalize(currentPath);
  const target = normalize(href);
  if (target === '/') return path === '/';
  return path === target || path.startsWith(`${target}/`);
};
---

<header class="site-header">
  <nav class="nav" aria-label="Primary">
    <a href="/" class="brand">{SITE.name}</a>

    <ul class="nav-links">
      {
        NAV_LINKS.map((link) => (
          <li>
            <a href={link.href} aria-current={isActive(link.href) ? 'page' : undefined}>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a class="cta" href={`tel:${BUSINESS.phone}`}>Call {BUSINESS.phoneDisplay}</a>
  </nav>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-white);
  }
  .nav {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .brand {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--color-dark);
    text-decoration: none;
  }
  .nav-links {
    display: flex;
    gap: 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
    margin-left: auto;
  }
  .nav-links a {
    color: var(--color-dark);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
  }
  .nav-links a:hover,
  .nav-links a[aria-current='page'] {
    color: var(--color-red);
  }
  .cta {
    background: var(--color-red);
    color: var(--color-white);
    text-decoration: none;
    padding: 0.5rem 0.9rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .cta:hover {
    background: #b01f1f;
  }
  @media (max-width: 640px) {
    .nav {
      flex-wrap: wrap;
      gap: 0.75rem;
    }
    .nav-links {
      margin-left: 0;
      order: 3;
      width: 100%;
      flex-wrap: wrap;
    }
  }
</style>
