---
/**
 * ContentMap.astro — responsive Google Map embed for the physical office.
 *
 * The pin is the REAL Google Business place for Lee's Plumbing Inc (its place id
 * is baked into the embed URL below), so the map lands on the verified listing
 * rather than a geocoded guess at the street. It maps the PHYSICAL location and
 * never the mailing P.O. Box: a P.O. Box is not a location, and dropping a map
 * pin on one would be wrong for customers and wrong for local SEO.
 *
 * Uses the keyless /maps/embed endpoint, so there is no API key to leak, no
 * billing to configure, and no third-party script on the page. It is a lazy
 * iframe, which keeps it off the critical path.
 *
 * The iframe carries a `title`, which is what a screen reader announces in place
 * of the map. The address is also rendered as text in ContactDetails, so the
 * information is never locked inside the embed.
 */
import { primaryOffice } from '../../data/offices';

const { address, name } = primaryOffice;
const query = `${address.street}, ${address.city}, ${address.region} ${address.postalCode}`;
// The verified Google Business place embed (contains Lee's Plumbing Inc's place
// id). Supplied by the business; reproduced exactly.
const embedSrc =
  "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2974.3316100107663!2d-111.83892770000001!3d41.7996163!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x87547d41a8637ce5%3A0xe1a12c574134d150!2sLee's%20Plumbing%20Inc!5e0!3m2!1sen!2sus!4v1784180377801!5m2!1sen!2sus";
const directionsHref = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(query)}`;
---

<div class="map-block">
  <div class="map-frame">
    <iframe
      src={embedSrc}
      title={`Google Map showing the location of Lee's Plumbing, ${query}`}
      loading="lazy"
      referrerpolicy="strict-origin-when-cross-origin"
      allowfullscreen></iframe>
  </div>
  <p class="map-caption">
    <span>{name}: {query}</span>
    <a href={directionsHref} target="_blank" rel="noopener noreferrer">Get directions</a>
  </p>
</div>

<style>
  .map-frame {
    /* Ratio is reserved, so the lazy iframe cannot shift the page when it
       loads. */
    aspect-ratio: 16 / 9;
    width: 100%;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-surface-alt);
  }
  .map-frame iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
  .map-caption {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    justify-content: space-between;
    align-items: baseline;
    margin: 0.9rem 0 0;
    font-size: 0.95rem;
    color: var(--color-muted);
  }
  .map-caption a {
    color: var(--color-red);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }
  .map-caption a:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .map-frame {
      aspect-ratio: 4 / 3;
    }
  }
</style>
