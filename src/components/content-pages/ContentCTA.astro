---
/**
 * ContentCTA.astro — the closing phone CTA for informational pages.
 *
 * The same conversion logic as the homepage's FinalCTASection: a phone call is
 * the outcome, so the band closes on the number and the hours and nothing else.
 * Kept separate from FinalCTASection because that component is part of the
 * homepage framework and this one is part of the content-page framework. They
 * are allowed to drift.
 *
 * Holds no business data. Phone, display number, and hours are passed in from
 * the central config by the page.
 */
interface Props {
  id?: string;
  heading: string;
  body?: string;
  ctaPrefix: string;
  phone: string;
  phoneDisplay: string;
  /** Pre-formatted, e.g. "Mon - Fri: 8:00 AM - 5:00 PM". */
  hours?: string[];
}

const { id = 'final-cta', heading, body, ctaPrefix, phone, phoneDisplay, hours = [] } = Astro.props;
const headingId = `${id}-heading`;
---

<section class="content-cta" aria-labelledby={headingId} {id}>
  <div class="container cta-inner">
    <h2 id={headingId}>{heading}</h2>
    {body && <p class="cta-body">{body}</p>}

    <a class="cta-button" href={`tel:${phone}`}>
      {ctaPrefix}
      {phoneDisplay}
    </a>

    {
      hours.length > 0 && (
        <div class="cta-hours">
          {hours.map((line) => (
            <p>{line}</p>
          ))}
        </div>
      )
    }
  </div>
</section>

<style>
  .content-cta {
    background: var(--color-dark);
    color: var(--color-white);
    padding: clamp(3.5rem, 7vw, 5.5rem) 0;
  }
  .cta-inner {
    text-align: center;
    max-width: 720px;
  }
  h2 {
    color: var(--color-white);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.12;
    margin: 0 0 1rem;
    text-wrap: balance;
  }
  .cta-body {
    margin: 0 auto 2rem;
    max-width: 54ch;
    font-size: 1.1rem;
    line-height: 1.7;
    color: #c9cccc;
  }
  .cta-button {
    display: inline-block;
    padding: 1.1rem 2.25rem;
    background: var(--color-red);
    color: var(--color-white);
    border-radius: var(--radius-sm);
    font-size: 1.15rem;
    font-weight: 700;
    text-decoration: none;
    transition: background-color 0.18s ease;
  }
  .cta-button:hover {
    background: var(--accent-dark);
  }
  .cta-button:focus-visible {
    outline: 3px solid var(--color-white);
    outline-offset: 3px;
  }
  .cta-hours {
    margin-top: 1.75rem;
    color: #9aa0a0;
    font-size: 0.95rem;
  }
  .cta-hours p {
    margin: 0.2rem 0;
  }

  @media (max-width: 480px) {
    .cta-button {
      display: block;
    }
  }
</style>
