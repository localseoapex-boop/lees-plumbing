---
/**
 * Footer.astro — site footer with a NAP block PER office (requirement #5).
 *
 * Iterates offices.ts so every physical location shows its own address, phone,
 * email, and hours in a semantic <address> element. This mirrors the
 * LocalBusiness schema exactly — consistent NAP across page + schema + external
 * listings is a core local-SEO ranking factor.
 *
 * The mailing-only P.O. Box comes from MAILING_ADDRESS in config/site.ts and is
 * rendered under its own "Mailing Address" label so it can never be mistaken for
 * the physical location.
 */
import { SITE, FOOTER_LINKS, MAILING_ADDRESS } from '../config/site';
import { offices, formatHours } from '../data/offices';
import BrandLogo from './BrandLogo.astro';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand-col">
      {/* tone="dark" renders the co-branded lockup on a white plaque, because
          its black "Lee's Plumbing" wordmark would otherwise vanish into the
          dark footer. BrandLogo owns that treatment; see its dark-tone rule. */}
      <div class="footer-brand">
        <BrandLogo tone="dark" />
      </div>
      <p class="footer-tagline">{SITE.description}</p>
    </div>

    {
      offices.map((office) => (
        <div class="footer-office">
          <p class="footer-heading">{office.name}</p>
          <address>
            {office.address.street}
            <br />
            {office.address.city}, {office.address.region} {office.address.postalCode}
            <br />
            <a href={`tel:${office.phone}`}>{office.phoneDisplay}</a>
            <br />
            <a href={`mailto:${office.email}`}>{office.email}</a>
          </address>
          <p class="footer-hours">{office.hours.map((spec) => formatHours(spec)).join(' / ')}</p>
        </div>
      ))
    }

    <div class="footer-office">
      <p class="footer-heading">Mailing Address</p>
      <address>
        {MAILING_ADDRESS.street}
        <br />
        {MAILING_ADDRESS.city}, {MAILING_ADDRESS.region} {MAILING_ADDRESS.postalCode}
      </address>
    </div>

    {
      FOOTER_LINKS.map((group) => (
        <nav class="footer-group" aria-label={group.title}>
          <p class="footer-heading">{group.title}</p>
          <ul>
            {group.links.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      ))
    }
  </div>

  <p class="footer-legal">
    &copy; {year} {offices[0].legalName}. All rights reserved.
  </p>
</footer>

<style>
  .site-footer {
    background: var(--color-dark);
    color: #d4d6d6;
    /* A hairline seam, NOT an external margin. The old `margin-top: 4rem` sat
       between the last section and the footer over the transparent <body>, so it
       painted as a 64px white band. That reads as an unexplained empty band
       wherever the final section is dark (the homepage close) or coloured (the
       red CTA that ends every service page). The footer now abuts the section
       above and delineates itself with the same 1px rule the legal line uses, so
       the two still read as separate sections with no white gap. The footer
       keeps its own internal top padding, so nothing feels cramped. */
    border-top: 1px solid #2a2e2e;
  }
  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 1rem 1.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 2rem;
  }
  .footer-brand-col {
    min-width: 220px;
  }
  .footer-brand {
    --brand-mark-height: 28px;
    --brand-word-size: 1.35rem;
    margin: 0 0 0.75rem;
  }
  .footer-tagline {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.6;
  }
  address {
    font-style: normal;
    line-height: 1.7;
    font-size: 0.9rem;
    /* PRE-EXISTING BUG, fixed here. "leesplumbinginc@hotmail.com" is a single
       228px unbreakable token, and in a narrow footer column it pushed the whole
       document past the viewport and produced horizontal scroll on phones around
       the 480px mark. An email address has no spaces to wrap at, so it needs
       explicit permission to break. */
    overflow-wrap: anywhere;
  }
  .footer-hours {
    margin: 0.5rem 0 0;
    font-size: 0.9rem;
  }
  .footer-heading {
    font-weight: 600;
    color: var(--color-white);
    margin: 0 0 0.75rem;
  }
  .footer-group ul {
    list-style: none;
    margin: 0;
    padding: 0;
    line-height: 1.9;
  }
  .site-footer a {
    color: #d4d6d6;
    text-decoration: none;
  }
  .site-footer a:hover {
    color: var(--color-white);
    text-decoration: underline;
  }
  .footer-legal {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.5rem 1rem;
    border-top: 1px solid #2a2e2e;
    font-size: 0.85rem;
    color: #a3a7a7;
  }
</style>
