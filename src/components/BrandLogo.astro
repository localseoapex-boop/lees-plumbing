---
/**
 * BrandLogo.astro — the one place the brand identity is rendered.
 *
 * Used by the header and the footer. It has TWO modes and prefers the first:
 *
 *   1. A real logo file, when one exists in BRAND_IMAGES for this surface. This
 *      is what ships today: the co-branded Lee's x Any Hour lockup is wired into
 *      both surfaces (see BRAND_IMAGES in config/images.ts).
 *   2. A LOCKUP fallback: the genuine red pipe-wrench mark plus the company name
 *      set in the brand heading font. Used only if the logo slots are cleared.
 *
 * The switch is automatic. Drop a real logo into BRAND_IMAGES.logoOnLight /
 * logoOnDark and every place the brand appears updates at once, with no
 * component edits anywhere.
 *
 * `tone` picks the surface. It matters: the co-branded lockup is black type on a
 * transparent ground, so tone="dark" backs it with a white plaque in the footer
 * (see the .brand-logo.dark rule) while tone="light" renders it bare on the white
 * header. In lockup fallback mode the wrench is red on both surfaces and the
 * wordmark takes the colour of the surface it sits on.
 *
 * SIZING is driven by two inherited custom properties, NOT by props:
 *   --brand-mark-height   height of the wrench mark   (default 30px)
 *   --brand-word-size     font-size of the wordmark   (default 1.5rem)
 * Custom properties inherit, so a caller can set them on its own wrapper and
 * change them per breakpoint in a media query. Inline styles would have won the
 * cascade and made the header impossible to size responsively.
 *
 * The mark keeps its aspect ratio (height is set, width is auto against the
 * intrinsic 177x192) so it can never be stretched, and at ~30px it renders at a
 * sixth of its native height, so it stays crisp on any display.
 *
 * ACCESSIBLE NAME. The company name is emitted exactly once in either mode:
 *   - logo mode: the <img> carries alt="Lee's Plumbing".
 *   - lockup mode: the mark is alt="" (decorative) and the name is real text.
 */
import { SITE } from '../config/site';
import { BRAND_IMAGES } from '../config/images';

interface Props {
  /** 'light' = dark artwork on a white surface. 'dark' = knockout on black. */
  tone?: 'light' | 'dark';
}

const { tone = 'light' } = Astro.props;

const logo = tone === 'dark' ? BRAND_IMAGES.logoOnDark : BRAND_IMAGES.logoOnLight;
const mark = BRAND_IMAGES.mark;
---

{
  logo ? (
    <img
      class:list={['brand-logo', tone]}
      src={logo.src}
      alt={logo.alt || SITE.name}
      width={logo.width}
      height={logo.height}
    />
  ) : (
    <span class:list={['brand-lockup', tone]}>
      {mark && (
        <img class="brand-mark" src={mark.src} alt="" width={mark.width} height={mark.height} />
      )}
      <span class="brand-word">{SITE.name}</span>
    </span>
  )
}

<style>
  .brand-logo {
    display: block;
    /* Height-driven so the wide lockup keeps its aspect ratio and can never be
       stretched. A caller can override --brand-logo-height directly; otherwise it
       tracks the same --brand-mark-height the responsive header already shrinks. */
    height: var(--brand-logo-height, calc(var(--brand-mark-height, 30px) + 12px));
    width: auto;
    max-width: 100%;
  }
  /* The co-branded lockup is black "LEE'S PLUMBING" ink on a transparent ground.
     It reads as-is on the white header (tone="light"), but on the dark footer
     (tone="dark") the wordmark would disappear, so it sits on a white plaque.
     content-box keeps the artwork at --brand-logo-height and adds the padding
     around it rather than shrinking the logo. */
  .brand-logo.dark {
    box-sizing: content-box;
    background: var(--color-white);
    padding: 0.5rem 0.7rem;
    border-radius: var(--radius-lg, 14px);
  }

  .brand-lockup {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    line-height: 1;
  }
  .brand-mark {
    display: block;
    flex: none;
    height: var(--brand-mark-height, 30px);
    /* Auto against the intrinsic 177x192, so the mark can never be stretched
       and never enlarged past its own pixels. */
    width: auto;
  }
  .brand-word {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--brand-word-size, 1.5rem);
    letter-spacing: 0.01em;
    white-space: nowrap;
  }
  .brand-lockup.light .brand-word {
    color: var(--color-dark);
  }
  .brand-lockup.dark .brand-word {
    color: var(--color-white);
  }
</style>
