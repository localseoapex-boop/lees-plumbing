---
/**
 * CityLayout.astro — template for /locations/[city] pages.
 *
 * Data-driven from a Location object. Builds the city hero, breadcrumbs, the
 * list of services available in that city (each linking to the dedicated
 * location-service page), and nearby-city links. The serving office's phone is
 * resolved via officeId so the CTA is locally relevant.
 */
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import InternalLinks from '../components/InternalLinks.astro';
import type { Location } from '../data/locations';
import { SITE } from '../config/site';
import { getOffice, primaryOffice } from '../data/offices';
import { servicesForLocation, nearbyCities } from '../lib/links';
import { cityUrl, serviceUrl, LOCATIONS_URL } from '../lib/urls';

interface Props {
  location: Location;
}

const { location } = Astro.props;
const office = getOffice(location.officeId) ?? primaryOffice;

const title = `Plumbing and HVAC Services in ${location.city}, ${location.region}`;
const description = `Plumbing, heating, and cooling services for ${location.city}, ${location.region} homeowners from ${SITE.name}.`;

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Service Areas', href: LOCATIONS_URL },
  { name: `${location.city}, ${location.region}` },
];

// City-service and city-sub-service pages no longer exist, so a city page links
// UP to the two core service hubs rather than sideways into a matrix of
// near-duplicate combination pages.
const serviceLinks = servicesForLocation(location).map((s) => ({
  label: s.name,
  href: serviceUrl(s.slug),
  description: s.tagline,
}));

// Nearby cities for lateral internal linking.
const nearbyLinks = nearbyCities(location.slug).map((loc) => ({
  label: `${loc.city}, ${loc.region}`,
  href: cityUrl(loc.slug),
}));
---

<BaseLayout {title} {description}>
  <article class="container page">
    <Breadcrumbs items={crumbs} />

    <header class="page-hero">
      <p class="eyebrow">Serving {location.city}, {location.region}</p>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
      <a class="cta" href={`tel:${office.phone}`}>Call {office.phoneDisplay}</a>
    </header>

    <div class="page-body">
      <p>
        {SITE.name} works out of {office.name.replace(' Office', '')} and serves {location.city} and
        the surrounding Cache Valley communities.
      </p>
    </div>

    <InternalLinks title={`Services we offer in ${location.city}`} links={serviceLinks} />
    <InternalLinks title="Nearby cities we serve" links={nearbyLinks} />
  </article>
</BaseLayout>
