---
/**
 * ServiceLayout.astro — the SERVICE HUB template (/services/[service]).
 *
 * Hubs exist to rank for broad category terms, convert, and pass authority down
 * to every sub-service beneath them. The composition below is deliberately NOT
 * the same as SubServiceLayout's: a hub leads with the sub-service DIRECTORY,
 * which is its most valuable block, and carries no signs / causes / process
 * sections, because those serve specific intent and belong on the pages that
 * answer it.
 *
 * Section order:
 *   1. Hero (conversion)      5. Reviews
 *   2. Supporting content     6. Service areas
 *   3. Sub-service directory  7. FAQs
 *   4. Trust                  8. Final CTA
 *
 * This layout ASSEMBLES components and holds no page copy of its own. All copy
 * comes from data/service-content.ts, keyed by category slug.
 *
 * Used ONLY by /services/[service]. The location tiers render through
 * LocationServiceLayout and LocationSubServiceLayout and are untouched by
 * anything in this file.
 */
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

import ServiceHero from '../components/services/ServiceHero.astro';
import SupportingContent from '../components/services/SupportingContent.astro';
import SubserviceDirectory from '../components/services/SubserviceDirectory.astro';
import FaqSection from '../components/services/FaqSection.astro';
import ServiceFinalCta from '../components/services/ServiceFinalCta.astro';

// Reused as-is from the homepage framework. All three are already generic and
// prop-driven, so copying them would have meant maintaining two of each.
import TrustSection from '../components/homepage/TrustSection.astro';
import ReviewsSection from '../components/homepage/ReviewsSection.astro';
import ServiceAreasSection from '../components/homepage/ServiceAreasSection.astro';

import { BUSINESS, SITE } from '../config/site';
import { primaryOffice, formatHours } from '../data/offices';
import type { Service } from '../data/services';
import { subServices } from '../data/subservices';
import { linkableCitiesForService } from '../lib/links';
import { serviceUrl, cityUrl, subServiceUrl, absoluteUrl } from '../lib/urls';
import { HQ_CITY_SLUG, getLocation } from '../data/locations';
import { getHubContent, TRUST_HEADING, TRUST_CARDS, REVIEWS } from '../data/service-content';
// The real fleet photograph — the same proof asset the homepage Trust band uses.
// Passing it here gives every hub the same evidence beat instead of a flat slab.
import { HOMEPAGE_IMAGES } from '../config/images';

interface Props {
  service: Service;
}

const { service } = Astro.props;

// data/service-content.ts already throws at build time if a category has no hub
// content. This check is what proves that to TypeScript.
const content = getHubContent(service.slug);
if (!content) {
  throw new Error(`ServiceLayout: no hub content for category "${service.slug}".`);
}

const title = `${service.name} Services`;
const description = service.description;
const hours = formatHours(primaryOffice.hours[0]);

// Home > Plumbing. There is no /services/ tier at launch, so the hub sits one
// level below the homepage.
const crumbs = [{ name: 'Home', href: '/' }, { name: service.name }];

// Directory groups, resolved from slugs to real sub-service records. The build
// guarantees every slug here exists, belongs to this category, and that no
// sub-service in the category was left out of the directory.
const groups = content.groups.map((group) => ({
  title: group.title,
  entries: group.slugs.map((slug) => {
    const sub = subServices.find((s) => s.slug === slug)!;
    return {
      name: sub.name,
      description: sub.tagline,
      href: subServiceUrl(service.slug, sub.slug),
    };
  }),
}));

// Service areas link to the NINE city pages. Hyde Park leads the grid as the
// headquarters but carries no link: it has no city page, because this page is
// already the Hyde Park page for this service.
const hq = getLocation(HQ_CITY_SLUG)!;
const areas = [
  { city: hq.city, region: hq.region, href: null, isHeadquarters: true },
  ...linkableCitiesForService(service.slug).map((loc) => ({
    city: loc.city,
    region: loc.region,
    href: cityUrl(loc.slug),
    isHeadquarters: false,
  })),
];

// Unchanged from the previous template: one Service node per page, provider
// pointing at the LocalBusiness graph. No FAQPage schema is emitted (see report).
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: service.name,
  provider: { '@id': `${SITE.url}/#business` },
  areaServed: BUSINESS.areaServed,
  url: absoluteUrl(serviceUrl(service.slug)),
};
---

<BaseLayout {title} {description}>
  <div class="container crumb-bar">
    <Breadcrumbs items={crumbs} />
  </div>

  <ServiceHero
    eyebrow="Based in Hyde Park, Serving Cache Valley"
    heading={content.heroHeading}
    lede={content.heroLede}
    phone={BUSINESS.phone}
    phoneDisplay={BUSINESS.phoneDisplay}
    {hours}
    secondaryCtaLabel="Explore Services"
    secondaryCtaHref="#services"
  />

  <SupportingContent
    id="about-service"
    heading={content.supportingHeading}
    paragraphs={content.supportingParagraphs}
  />

  <SubserviceDirectory
    id="services"
    heading={content.directoryHeading}
    intro={content.directoryIntro}
    {groups}
  />

  <TrustSection
    id="why-us"
    heading={TRUST_HEADING}
    intro={content.trustIntro}
    cards={TRUST_CARDS}
    image={HOMEPAGE_IMAGES.trustTrucks}
  />

  <ReviewsSection
    id="reviews"
    heading={REVIEWS.heading}
    items={[]}
    isPlaceholder={REVIEWS.isPlaceholder}
    emptyMessage={REVIEWS.emptyMessage}
  />

  {/* ServiceAreasSection renders its own `id`, which is the #areas anchor target
      for the final CTA's "See our service areas" link. */}
  <ServiceAreasSection id="areas" heading={content.areasHeading} intro={content.areasIntro} {areas} />

  <FaqSection id="faqs" heading={content.faqHeading} items={content.faqs} />

  <ServiceFinalCta
    heading={content.finalCtaHeading}
    body={content.finalCtaBody}
    phone={BUSINESS.phone}
    phoneDisplay={BUSINESS.phoneDisplay}
    {hours}
    secondaryLabel="See our service areas"
    secondaryHref="#areas"
  />

  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} is:inline />
</BaseLayout>

<style>
  /* The breadcrumb sits on white above the dark hero. */
  .crumb-bar {
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
</style>
