---
/**
 * BaseLayout.astro — the root HTML shell every page renders inside.
 *
 * Composes the global pieces: BaseHead (SEO meta), Navigation, Footer, and the
 * LocalBusiness schema. It forwards SEO props through to BaseHead so each page
 * controls its own title/description/canonical while inheriting one consistent
 * document structure. Page content is injected through the <slot />.
 *
 * The specialized templates (Service/City/BlogPost) build ON TOP of this layout,
 * so global concerns live here and only here. That includes the brand tokens in
 * the :root block below, which every component styles against.
 */
import BaseHead from '../components/BaseHead.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
import { SITE } from '../config/site';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}

const { title, description, image, type, noindex } = Astro.props;
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <BaseHead {title} {description} {image} {type} {noindex} />
    <LocalBusinessSchema />
  </head>
  <body>
    <Navigation />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  /* Brand tokens. Colors and fonts are defined ONCE here and referenced
     everywhere else through these variables. */
  :root {
    --content-width: 1100px;

    --color-dark: #050707;
    --color-red: #d22727;
    --color-white: #ffffff;

    --color-text: #050707;
    --color-muted: #5c6060;
    --color-border: #dfe2e2;
    --accent: #d22727;
    /* Darker red reserved for hover/active states on red surfaces. */
    --accent-dark: #b01f1f;

    --font-heading: 'Cormorant Garamond', Georgia, serif;
    --font-body: 'Montserrat', Arial, sans-serif;
  }
  * {
    box-sizing: border-box;
  }
  html {
    font-family: var(--font-body);
    color: var(--color-text);
    line-height: 1.6;
  }
  body {
    margin: 0;
  }
  main {
    min-height: 60vh;
  }
  a {
    color: var(--accent);
  }
  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: var(--font-heading);
    line-height: 1.2;
    color: var(--color-dark);
  }
  img {
    max-width: 100%;
    height: auto;
  }
  .container {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 1rem;
  }

  /* Shared landing-page primitives, used by the Service / City / Location-Service
     templates so per-template CSS stays minimal and the look is consistent. */
  .page {
    padding: 0 1rem 3rem;
  }
  .page-hero {
    padding: 1.5rem 0 0;
  }
  .page-hero h1 {
    font-size: 2.75rem;
    margin: 0.25rem 0 0.75rem;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    color: var(--accent);
    font-weight: 600;
    margin: 0;
  }
  .lede {
    font-size: 1.2rem;
    color: var(--color-muted);
    max-width: 60ch;
  }
  .cta {
    display: inline-block;
    margin-top: 1rem;
    background: var(--accent);
    color: var(--color-white);
    text-decoration: none;
    padding: 0.75rem 1.25rem;
    border-radius: 8px;
    font-weight: 600;
  }
  .cta:hover {
    background: var(--accent-dark);
  }
  .page-body {
    margin-top: 2.5rem;
    max-width: 70ch;
  }
</style>
