---
/**
 * /plumbing — the plumbing hub. Targets "Plumbing Services in Hyde Park, Utah".
 *
 * A static route rather than a dynamic /[category] one: the category lives at a
 * hand-chosen URL (/plumbing), and spelling it out keeps the routing obvious.
 * This file resolves the category and hands it to the approved ServiceLayout. It
 * contains no markup of its own.
 */
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import { getService } from '../../data/services';

const service = getService('plumbing');
if (!service) throw new Error('/plumbing: the "plumbing" service is missing from data/services.ts');
---

<ServiceLayout {service} />
