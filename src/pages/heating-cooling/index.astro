---
/**
 * /heating-cooling — the heating and cooling hub.
 * Targets "Heating and Cooling Services in Hyde Park, Utah".
 *
 * The URL segment is 'heating-cooling' while the internal service slug stays
 * 'hvac' (see data/services.ts `routeSegment`). The route reads the way a
 * homeowner searches; the slug stays the key everything else is wired to.
 */
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import { getService } from '../../data/services';

const service = getService('hvac');
if (!service) {
  throw new Error('/heating-cooling: the "hvac" service is missing from data/services.ts');
}
---

<ServiceLayout {service} />
