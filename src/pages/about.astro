---
/**
 * /about — About Lee's Plumbing, the definitive company story.
 *
 * Composition:
 *   1. Photographic hero (a plumber's hands at work, behind the H1)
 *   2. History of Lee's Plumbing — the company story and community roots
 *   3. "Hi, I'm Lee. Call Me!" — remodel work
 *   4. Visit Our Hyde Park Showroom — the physical Hyde Park presence
 *   5. Our Expertise + Product Brands — what we work on
 *   6. Why Homeowners Choose Lee's Plumbing — the trust band with the REAL fleet
 *      photograph (proof)
 *   7. Reviews — the real Google reviews reused from the homepage
 *   8. Closing phone CTA
 *
 * This file holds NO copy: all of it comes from ABOUT_PAGE in
 * config/content-pages.ts (plus the shared trust/reviews config), and every image
 * path comes from config/images.ts.
 *
 * The remodel and showroom media slots are DELIBERATELY left as branded fallback
 * panels: they depict Lee's own completed work and facility, so they must be real
 * client photography, never AI, and they stay as honest placeholders until that
 * photography exists (see config/images.ts).
 *
 * The Any Hour partnership is NOT mentioned here, by design. This page is about
 * Lee's Plumbing. The single <h1> is rendered by ContentLayout's hero.
 */
import ContentLayout from '../layouts/ContentLayout.astro';
import ContentSection from '../components/content-pages/ContentSection.astro';
import ContentCTA from '../components/content-pages/ContentCTA.astro';
// Shared bands, same as the homepage, so the page rhymes with the rest of the site.
import TrustSection from '../components/homepage/TrustSection.astro';
import ReviewsSection from '../components/homepage/ReviewsSection.astro';

import { BUSINESS } from '../config/site';
import { ABOUT_PAGE } from '../config/content-pages';
import { REVIEWS } from '../config/homepage';
import { ABOUT_IMAGES, HOMEPAGE_IMAGES } from '../config/images';
import { TRUST_HEADING, TRUST_CARDS } from '../data/service-content';
import { primaryOffice, formatHours } from '../data/offices';

const hours = primaryOffice.hours.map((spec) => formatHours(spec));
const crumbs = [{ name: 'Home', href: '/' }, { name: "About Lee's Plumbing" }];
---

<ContentLayout
  title={ABOUT_PAGE.title}
  description={ABOUT_PAGE.description}
  {crumbs}
  eyebrow={ABOUT_PAGE.eyebrow}
  heading={ABOUT_PAGE.heading}
  lede={ABOUT_PAGE.lede}
  heroBgImage={ABOUT_IMAGES.heroBg}
>
  <ContentSection
    id="history"
    heading={ABOUT_PAGE.history.heading}
    paragraphs={ABOUT_PAGE.history.paragraphs}
    surface="white"
  />

  <ContentSection
    id="remodels"
    heading={ABOUT_PAGE.remodels.heading}
    paragraphs={ABOUT_PAGE.remodels.paragraphs}
    asset={ABOUT_IMAGES.remodel}
    fallbackCaption="Remodel Work"
    media="right"
    surface="alt"
  />

  <ContentSection
    id="showroom"
    heading={ABOUT_PAGE.showroom.heading}
    paragraphs={ABOUT_PAGE.showroom.paragraphs}
    closing={ABOUT_PAGE.showroom.closing}
    asset={ABOUT_IMAGES.showroom}
    fallbackCaption="Hyde Park Showroom"
    media="left"
    surface="white"
  />

  <ContentSection id="expertise" heading={ABOUT_PAGE.expertise.heading} surface="alt">
    <p>{ABOUT_PAGE.expertise.intro}</p>

    <div class="expertise-grid">
      {
        ABOUT_PAGE.expertise.groups.map((group) => (
          <div class="expertise-card">
            <h3>{group.title}</h3>
            <ul>
              {group.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </ContentSection>

  <ContentSection id="brands" heading={ABOUT_PAGE.brands.heading} surface="white">
    <p>{ABOUT_PAGE.brands.intro}</p>

    {/* Names only. No logos are reproduced and no dealer status is claimed. */}
    <ul class="brand-list">
      {ABOUT_PAGE.brands.items.map((brand) => <li>{brand}</li>)}
    </ul>
  </ContentSection>

  {/* Why homeowners trust Lee's + the real fleet photograph as proof. */}
  <TrustSection
    id="why-us"
    heading={TRUST_HEADING}
    intro="A local plumbing company that answers the phone and does the work properly."
    cards={TRUST_CARDS}
    image={HOMEPAGE_IMAGES.trustTrucks}
  />

  <ReviewsSection
    id="reviews"
    heading={REVIEWS.heading}
    intro={REVIEWS.intro}
    items={REVIEWS.items}
    isPlaceholder={REVIEWS.isPlaceholder}
    emptyMessage={REVIEWS.emptyMessage}
    ctaLabel={REVIEWS.ctaLabel}
    ctaHref={REVIEWS.ctaHref}
  />

  <ContentCTA
    heading={ABOUT_PAGE.cta.heading}
    body={ABOUT_PAGE.cta.body}
    ctaPrefix={ABOUT_PAGE.cta.ctaPrefix}
    phone={BUSINESS.phone}
    phoneDisplay={BUSINESS.phoneDisplay}
    {hours}
  />
</ContentLayout>

<style>
  .expertise-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .expertise-card {
    padding: 1.6rem;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }
  .expertise-card h3 {
    margin: 0 0 1rem;
    font-size: 1.3rem;
  }
  .expertise-card ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }
  .expertise-card li {
    position: relative;
    padding-left: 1.3rem;
    font-size: 0.95rem;
    color: var(--color-dark);
  }
  .expertise-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-red);
  }

  .brand-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
  }
  .brand-list li {
    padding: 0.65rem 1.25rem;
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-dark);
  }
</style>
