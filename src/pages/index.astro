---
/**
 * Homepage (/) — uses BaseLayout directly (it's not a service/city/blog page).
 *
 * Passes the geo-targeted title WITHOUT the brand: BaseHead appends "| {brand}"
 * for any title that isn't the bare brand name, so the rendered title is
 * "Plumber in Hyde Park, UT | Lee's Plumbing" and the brand is never doubled.
 * Cards link into the two service categories and the service-area hub for
 * internal-link equity.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { BUSINESS } from '../config/site';

const title = 'Plumber in Hyde Park, UT';
const description =
  "Lee's Plumbing provides trusted plumbing, heating, and cooling services in Hyde Park and communities across Cache Valley. Call 435-563-0611.";
---

<BaseLayout {title} {description}>
  <section class="hero container">
    <h1>Trusted Plumbing and HVAC Services in Hyde Park, Utah</h1>
    <p class="lede">
      Plumbing, heating, and cooling services for homeowners in Hyde Park and communities across
      Cache Valley.
    </p>
    <div class="hero-actions">
      <a class="btn primary" href={`tel:${BUSINESS.phone}`}>Call {BUSINESS.phoneDisplay}</a>
      <a class="btn" href="/services/plumbing">View plumbing services</a>
    </div>
  </section>

  <section class="container grid">
    <a class="card" href="/services/plumbing">
      <h2>Plumbing</h2>
      <p>Leaks, water heaters, pipes, fixtures, and drains.</p>
    </a>
    <a class="card" href="/services/hvac">
      <h2>Heating &amp; Cooling</h2>
      <p>Furnaces, air conditioners, heat pumps, and maintenance.</p>
    </a>
    <a class="card" href="/locations">
      <h2>Service Areas</h2>
      <p>Serving Hyde Park, Logan, and communities across Cache Valley.</p>
    </a>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 4rem 1rem 2rem;
    text-align: center;
  }
  .hero h1 {
    font-size: 3rem;
    margin: 0 0 1rem;
  }
  .lede {
    font-size: 1.25rem;
    color: var(--color-muted);
    max-width: 60ch;
    margin: 0 auto 1.5rem;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn {
    padding: 0.75rem 1.25rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    border: 1px solid var(--accent);
    color: var(--accent);
  }
  .btn.primary {
    background: var(--accent);
    color: var(--color-white);
  }
  .btn.primary:hover {
    background: var(--accent-dark);
    border-color: var(--accent-dark);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    padding-top: 2rem;
  }
  .card {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s;
  }
  .card:hover {
    border-color: var(--accent);
  }
  .card h2 {
    margin: 0 0 0.5rem;
  }
  .card p {
    margin: 0;
    color: var(--color-muted);
  }
</style>
