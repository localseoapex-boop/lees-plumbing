---
/**
 * Homepage (/) — assembles the reusable homepage framework.
 *
 * This file contains NO copy and NO markup of its own. Its only jobs are:
 *   1. resolve content from config/homepage.ts against the service + location
 *      data built in Phase 1, and
 *   2. hand the result to the generic components in components/homepage/.
 *
 * That split is the whole point of the framework: a different business swaps
 * config/homepage.ts plus its data files and gets this homepage for free,
 * without editing a single component.
 *
 * SEO notes:
 *   - The <h1> lives in HeroSection and is the ONLY h1 on the page. Section
 *     headings are <h2>, card titles <h3>.
 *   - Title is passed WITHOUT the brand: BaseHead appends "| {brand}" so the
 *     rendered title stays "Plumber in Hyde Park, UT | Lee's Plumbing".
 *   - Featured services are resolved from the sub-service catalog by slug, so
 *     every card links to a page that is guaranteed to exist.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/homepage/HeroSection.astro';
import TrustStrip from '../components/homepage/TrustStrip.astro';
import ServiceSection from '../components/homepage/ServiceSection.astro';
import TrustSection from '../components/homepage/TrustSection.astro';
import ReviewsSection from '../components/homepage/ReviewsSection.astro';
import AboutSection from '../components/homepage/AboutSection.astro';
import ServiceAreasSection from '../components/homepage/ServiceAreasSection.astro';
import FinalCTASection from '../components/homepage/FinalCTASection.astro';

import { BUSINESS } from '../config/site';
import {
  HERO,
  TRUST_STRIP,
  PLUMBING_SECTION,
  HVAC_SECTION,
  WHY_US,
  REVIEWS,
  ABOUT,
  SERVICE_AREAS,
  FINAL_CTA,
  type ServiceSectionContent,
} from '../config/homepage';
import { HOMEPAGE_IMAGES } from '../config/images';
import { getService } from '../data/services';
import { getSubService } from '../data/subservices';
import { locations, HQ_CITY_SLUG, hasCityPage } from '../data/locations';
import { primaryOffice, formatHours } from '../data/offices';
import { serviceUrl, subServiceUrl, cityUrl } from '../lib/urls';

/**
 * Turn a configured section into rendered cards + CTA target. Any featured slug
 * that does not resolve to a real sub-service is DROPPED rather than rendered
 * as a dead link, so a typo in the config can never ship a broken internal link.
 */
function resolveServiceSection(content: ServiceSectionContent) {
  const service = getService(content.serviceSlug);
  if (!service) throw new Error(`Unknown service slug: ${content.serviceSlug}`);

  const cards = content.featured.flatMap((item) => {
    const sub = getSubService(content.serviceSlug, item.slug);
    if (!sub) return [];
    return [
      {
        name: sub.name,
        href: subServiceUrl(content.serviceSlug, sub.slug),
        blurb: item.blurb ?? sub.tagline,
      },
    ];
  });

  return { cards, ctaHref: serviceUrl(service.slug) };
}

const plumbing = resolveServiceSection(PLUMBING_SECTION);
const hvac = resolveServiceSection(HVAC_SECTION);

// All ten cities appear in the grid, because all ten are served. Only the nine
// with a page are LINKED: Hyde Park is the HQ, it has no city page, and this
// homepage is already the page that targets it. A null href renders it as an
// emphasized but non-interactive card rather than a link to nowhere.
const areas = locations.map((loc) => ({
  city: loc.city,
  region: loc.region,
  href: hasCityPage(loc.slug) ? cityUrl(loc.slug) : null,
  isHeadquarters: loc.slug === HQ_CITY_SLUG,
}));

const hours = primaryOffice.hours.map((spec) => formatHours(spec));

/**
 * Scheduling CTA. Now resolves to the contact page. The `?? tel:` fallback is
 * kept deliberately: it is the framework's safety net, so a future Local SEO
 * Apex business that launches before its contact page exists still gets a
 * working CTA instead of a link to nowhere. The number is resolved from
 * BUSINESS, never hardcoded in a component.
 */
const heroPrimaryCta = {
  label: HERO.primaryCta.label,
  href: HERO.primaryCta.href ?? `tel:${BUSINESS.phone}`,
};

// The closing band's primary action, resolved the same way as the hero's: the
// contact page when it exists, the phone as the framework's safety-net fallback.
const finalPrimaryCta = {
  label: FINAL_CTA.primaryCta.label,
  href: FINAL_CTA.primaryCta.href ?? `tel:${BUSINESS.phone}`,
};

const title = 'Plumber in Hyde Park, UT';
const description =
  "Lee's Plumbing provides trusted plumbing, heating, and cooling services in Hyde Park and communities across Cache Valley. Call 435-563-0611.";
---

<BaseLayout {title} {description}>
  <HeroSection
    eyebrow={HERO.eyebrow}
    heading={HERO.heading}
    body={HERO.body}
    primaryCta={heroPrimaryCta}
    phone={BUSINESS.phone}
    phoneDisplay={BUSINESS.phoneDisplay}
    secondaryCtaPrefix={HERO.secondaryCtaPrefix}
    background={{ desktop: HOMEPAGE_IMAGES.heroDesktop, mobile: HOMEPAGE_IMAGES.heroMobile }}
  />

  <TrustStrip items={TRUST_STRIP} />

  {/* The opening-spread plate. No plumbing photograph exists yet, so this is
      null and the branded fallback renders; when a real photo lands, set
      HOMEPAGE_IMAGES.plumbing and nothing else changes. */}
  <ServiceSection
    id="plumbing"
    heading={PLUMBING_SECTION.heading}
    intro={PLUMBING_SECTION.intro}
    cards={plumbing.cards}
    ctaLabel={PLUMBING_SECTION.ctaLabel}
    ctaHref={plumbing.ctaHref}
    emphasis="primary"
    image={HOMEPAGE_IMAGES.plumbing}
  />

  {/* The real fleet photograph is the evidence for what this section claims. */}
  <TrustSection
    id="why-us"
    heading={WHY_US.heading}
    intro={WHY_US.intro}
    cards={WHY_US.cards}
    image={HOMEPAGE_IMAGES.trustTrucks}
  />

  <ServiceSection
    id="hvac"
    heading={HVAC_SECTION.heading}
    intro={HVAC_SECTION.intro}
    cards={hvac.cards}
    ctaLabel={HVAC_SECTION.ctaLabel}
    ctaHref={hvac.ctaHref}
    emphasis="secondary"
  />

  <ReviewsSection
    id="reviews"
    heading={REVIEWS.heading}
    intro={REVIEWS.intro}
    items={REVIEWS.items}
    isPlaceholder={REVIEWS.isPlaceholder}
    emptyMessage={REVIEWS.emptyMessage}
    ctaLabel={REVIEWS.ctaLabel}
    ctaHref={REVIEWS.ctaHref}
  />

  <AboutSection
    id="about"
    heading={ABOUT.heading}
    paragraphs={ABOUT.paragraphs}
    highlights={ABOUT.highlights}
    ctaLabel={ABOUT.ctaLabel}
    ctaHref={ABOUT.ctaHref}
    image={HOMEPAGE_IMAGES.about}
  />

  <ServiceAreasSection
    id="service-areas"
    heading={SERVICE_AREAS.heading}
    intro={SERVICE_AREAS.intro}
    areas={areas}
    headquartersLabel={SERVICE_AREAS.headquartersLabel}
  />

  <FinalCTASection
    id="final-cta"
    heading={FINAL_CTA.heading}
    body={FINAL_CTA.body}
    primaryCta={finalPrimaryCta}
    ctaPrefix={FINAL_CTA.ctaPrefix}
    phone={BUSINESS.phone}
    phoneDisplay={BUSINESS.phoneDisplay}
    {hours}
  />
</BaseLayout>
